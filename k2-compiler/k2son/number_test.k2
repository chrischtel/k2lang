#import number_utils;

bytes_eq :: fn(buffer: []const u8, len: usize, expected: []const u8) -> bool {
    if len != expected.len { return false; }
    i := 0usize;
    while i < len {
        if buffer[i] != expected[i] { return false; }
        i += 1usize;
    }
    return true;
}

check_parse_integers :: fn() -> i32 {
    zero := parse_json_number("0") catch err { return 1; };
    if zero.consumed != 1usize || zero.value != 0.0 || !zero.is_integer { return 2; }

    positive := parse_json_number("123,") catch err { return 3; };
    if positive.consumed != 3usize || positive.value != 123.0 || !positive.is_integer { return 4; }

    negative := parse_json_number("-42}") catch err { return 5; };
    if negative.consumed != 3usize || negative.value != -42.0 || !negative.is_integer { return 6; }

    leading_zero := parse_json_number("0123") catch err { return 7; };
    if leading_zero.consumed != 1usize || leading_zero.value != 0.0 { return 8; }

    return 0;
}

check_parse_floats :: fn() -> i32 {
    frac := parse_json_number("3.5 ") catch err { return 11; };
    if frac.consumed != 3usize || frac.value != 3.5 || frac.is_integer { return 12; }

    exp := parse_json_number("1e3") catch err { return 13; };
    if exp.consumed != 3usize || exp.value != 1000.0 || exp.is_integer { return 14; }

    neg_exp := parse_json_number("1.5e-2]") catch err { return 15; };
    if neg_exp.consumed != 6usize { return 16; }
    diff := neg_exp.value - 0.015;
    if diff < 0.0 { diff = -diff; }
    if diff > 0.0000000001 { return 17; }

    plus_exp := parse_json_number("2E+5") catch err { return 18; };
    if plus_exp.consumed != 4usize || plus_exp.value != 200000.0 { return 19; }

    return 0;
}

check_parse_empty :: fn() -> i32 {
    parse_json_number("") catch err {
        if err == .empty_input { return 0; }
        return 21;
    };
    return 22;
}

check_parse_lone_minus :: fn() -> i32 {
    parse_json_number("-") catch err {
        if err == .invalid_number { return 0; }
        return 31;
    };
    return 32;
}

check_parse_trailing_dot :: fn() -> i32 {
    parse_json_number("1.") catch err {
        if err == .invalid_number { return 0; }
        return 41;
    };
    return 42;
}

check_format_integers :: fn() -> i32 {
    buf: [32]u8 = .{};

    n := format_u64(0u64, buf[:]) catch err { return 51; };
    if !bytes_eq(buf[:], n, "0") { return 52; }

    n = format_u64(18446744073709551615u64, buf[:]) catch err { return 53; };
    if !bytes_eq(buf[:], n, "18446744073709551615") { return 54; }

    n = format_i64(0i64, buf[:]) catch err { return 55; };
    if !bytes_eq(buf[:], n, "0") { return 56; }

    n = format_i64(-42i64, buf[:]) catch err { return 57; };
    if !bytes_eq(buf[:], n, "-42") { return 58; }

    n = format_i64(-9223372036854775808i64, buf[:]) catch err { return 59; };
    if !bytes_eq(buf[:], n, "-9223372036854775808") { return 60; }

    return 0;
}

check_format_floats :: fn() -> i32 {
    buf: [32]u8 = .{};

    n := format_f64(0.0, buf[:]) catch err { return 71; };
    if !bytes_eq(buf[:], n, "0") { return 72; }

    n = format_f64(-0.0, buf[:]) catch err { return 73; };
    if !bytes_eq(buf[:], n, "-0") { return 74; }

    n = format_f64(1.0, buf[:]) catch err { return 75; };
    if !bytes_eq(buf[:], n, "1") { return 76; }

    n = format_f64(-123.0, buf[:]) catch err { return 77; };
    if !bytes_eq(buf[:], n, "-123") { return 78; }

    n = format_f64(0.5, buf[:]) catch err { return 79; };
    if !bytes_eq(buf[:], n, "0.5") { return 80; }

    return 0;
}

relative_error :: fn(a: f64, b: f64) -> f64 {
    if a == b { return 0.0; }
    diff := a - b;
    if diff < 0.0 { diff = -diff; }
    denom := b;
    if denom < 0.0 { denom = -denom; }
    if denom == 0.0 { return diff; }
    return diff / denom;
}

// Exact-string assertions above are limited to "0.5" (= 5 * 10^-1, reachable
// via a single decimal-shift multiplication that is provably exact in IEEE
// double rounding). For everything else (0.25, 3.14, scientific notation,
// 1/3, ...) the decimal spelling that `format_shortest_at` lands on depends
// on `pow10`'s chained rounding, which isn't worth hand-verifying bit by bit.
// The only meaningful correctness check there is round-tripping: format then
// parse must reproduce the exact same f64, whatever spelling was chosen.
check_round_trip :: fn() -> i32 {
    samples: [12]f64 = .{
        0.0, 1.0, -1.0, 0.1, 0.25, 3.14, 3.14159, 100.0,
        1.0 / 3.0, 1.0e100, 1.0e-100, 1.5e20,
    };

    buf: [64]u8 = .{};
    i := 0usize;
    while i < samples.len {
        value := samples[i];
        written := format_f64(value, buf[:]) catch err { return 90; };
        parsed := parse_json_number(buf[:]) catch err { return 91; };
        if parsed.consumed != written { return 92; }

        // Naive decimal<->binary conversion (both here and in the compiler's
        // own float-literal lexer) is not guaranteed correctly-rounded, so
        // bit-exact equality isn't a fair bar. A relative error far below the
        // ~2^-52 ULP of f64 still catches real bugs (wrong digits, misplaced
        // decimal point, exponent sign flips, ...).
        rel_err := relative_error(parsed.value, value);
        if rel_err > 0.0000000000001 { return 93; }
        i += 1usize;
    }
    return 0;
}

main :: fn() -> i32 {
    r := check_parse_integers();
    if r != 0 { return r; }

    r = check_parse_floats();
    if r != 0 { return r; }

    r = check_parse_empty();
    if r != 0 { return r; }

    r = check_parse_lone_minus();
    if r != 0 { return r; }

    r = check_parse_trailing_dot();
    if r != 0 { return r; }

    r = check_format_integers();
    if r != 0 { return r; }

    r = check_format_floats();
    if r != 0 { return r; }

    r = check_round_trip();
    if r != 0 { return r; }

    return 0;
}
