// Example project build script. Run with `k2 build` (once dir-mode lands).
// See docs/10_build_system.md for the full design.

#import std.build.{ Build, executable, shared, release, debug, link, lib_path,
                    output, define, require_path, depend, run_step, test_dir, default };

build :: fn(b: Build) {
    // The main executable.
    game := b.executable("game", "src/main.k2");
    game.release();
    game.link("raylib");
    game.link("user32");
    game.lib_path("vendor/raylib/lib");
    game.output("bin/game.exe");
    game.define("MAX_ENTITIES", "4096");

    // A build-time dependency (its own build.k2 runs sandboxed).
    rl := b.require_path("raylib", "vendor/raylib");
    game.depend(rl);

    // A second artifact: a hot-reloadable gameplay DLL.
    logic := b.shared("logic", "src/logic.k2");
    logic.debug();
    logic.output("bin/logic.dll");

    // Steps: `k2 build run`, `k2 build test`.
    b.run_step("run", game);
    b.test_dir("test", "tests/");

    // What bare `k2 build` produces.
    b.default(game);
}
