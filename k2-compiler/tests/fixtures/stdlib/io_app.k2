#import std.io.{
    Writer,
    stdout, stderr,
    print, println, eprint, eprintln,
    print_u64, print_i64, print_hex_u64, print_bool,
    eprint_u64, eprint_i64,
    write_all, write_line, write_char, write_repeat,
    write_u64, write_i64, write_bool,
    write_hex_byte, write_hex_u64, write_hex_u64_full,
    FixedBuf, fixed_buf, buf_len, buf_remaining, buf_reset,
    buf_flush_stdout, buf_flush_stderr, buf_flush,
    NullWriter, null_writer, null_reset,
};

// Print a horizontal rule to stdout.
rule :: fn() -> i32 {
    out := stdout();
    w: *Writer = &out;
    w.write_repeat(45u8, 40usize) catch err { return 1; };  // '-' == 45
    w.write_char(10u8) catch err { return 1; };             // '\n' == 10
    return 0;
}

run :: fn() -> i32 {
    // ── Section 1: Basic string output ───────────────────────────────────────
    println("K2 std.io showcase") catch err { return 1; };

    r := rule();
    if r != 0 { return r; }

    // ── Section 2: Unsigned integers ─────────────────────────────────────────
    print("u64 max:    ") catch err { return 2; };
    print_u64(18446744073709551615u64) catch err { return 2; };
    print("\n") catch err { return 2; };

    print("u64 zero:   ") catch err { return 2; };
    print_u64(0u64) catch err { return 2; };
    print("\n") catch err { return 2; };

    print("u64 value:  ") catch err { return 2; };
    print_u64(1234567890u64) catch err { return 2; };
    print("\n") catch err { return 2; };

    // ── Section 3: Signed integers ───────────────────────────────────────────
    print("i64 pos:    ") catch err { return 3; };
    print_i64(9223372036854775807i64) catch err { return 3; };  // i64 max
    print("\n") catch err { return 3; };

    print("i64 neg:    ") catch err { return 3; };
    print_i64(-1234567890i64) catch err { return 3; };
    print("\n") catch err { return 3; };

    print("i64 minus1: ") catch err { return 3; };
    print_i64(-1i64) catch err { return 3; };
    print("\n") catch err { return 3; };

    // ── Section 4: Boolean ───────────────────────────────────────────────────
    print("bools:      ") catch err { return 4; };
    print_bool(true) catch err { return 4; };
    print(" ") catch err { return 4; };
    print_bool(false) catch err { return 4; };
    print("\n") catch err { return 4; };

    // ── Section 5: Hex output ────────────────────────────────────────────────
    print("hex u64:    ") catch err { return 5; };
    print_hex_u64(3735928559u64) catch err { return 5; };   // 0xDEADBEEF
    print("\n") catch err { return 5; };

    print("hex zero:   ") catch err { return 5; };
    print_hex_u64(0u64) catch err { return 5; };
    print("\n") catch err { return 5; };

    print("hex full:   ") catch err { return 5; };
    out := stdout();
    fw: *Writer = &out;
    fw.write_hex_u64_full(72623859790382856u64) catch err { return 5; }; // 0x0102030405060708
    print("\n") catch err { return 5; };

    // ── Section 6: Hex byte dump ─────────────────────────────────────────────
    print("hex bytes:  ") catch err { return 6; };
    out2 := stdout();
    dw: *Writer = &out2;
    dw.write_hex_byte(0xDEu8) catch err { return 6; };
    dw.write_char(32u8) catch err { return 6; };    // space
    dw.write_hex_byte(0xADu8) catch err { return 6; };
    dw.write_char(32u8) catch err { return 6; };
    dw.write_hex_byte(0xBEu8) catch err { return 6; };
    dw.write_char(32u8) catch err { return 6; };
    dw.write_hex_byte(0xEFu8) catch err { return 6; };
    dw.write_char(10u8) catch err { return 6; };

    // ── Section 7: FixedBuf formatting ───────────────────────────────────────
    // Format a complex string into a stack buffer, then flush it.
    buf := fixed_buf();
    bw: *Writer = &buf;
    bw.write_all("fixed[") catch err { return 7; };
    bw.write_i64(-42i64) catch err { return 7; };
    bw.write_all(", ") catch err { return 7; };
    bw.write_u64(100u64) catch err { return 7; };
    bw.write_all(", ") catch err { return 7; };
    bw.write_bool(true) catch err { return 7; };
    bw.write_all("]: len=") catch err { return 7; };
    buflen := (&buf).buf_len();
    bw.write_u64(buflen as u64) catch err { return 7; };
    bw.write_char(10u8) catch err { return 7; };
    (&buf).buf_flush_stdout() catch err { return 7; };

    // Reset the buffer and reuse it.
    (&buf).buf_reset();
    bw.write_all("after reset: len=") catch err { return 7; };
    bw.write_u64((&buf).buf_len() as u64) catch err { return 7; };
    bw.write_char(10u8) catch err { return 7; };
    (&buf).buf_flush_stdout() catch err { return 7; };

    // ── Section 8: NullWriter byte counting ──────────────────────────────────
    // Measure how many bytes write_u64 would produce without writing anything.
    sink := null_writer();
    sw: *Writer = &sink;
    sw.write_u64(12345u64) catch err { return 8; };
    sw.write_i64(-9999i64) catch err { return 8; };
    sw.write_bool(false) catch err { return 8; };
    print("measured:   ") catch err { return 8; };
    print_u64(sink.count as u64) catch err { return 8; };   // 5 + 5 + 5 = 15
    print(" bytes\n") catch err { return 8; };

    // Reset and measure again.
    (&sink).null_reset();
    sw.write_hex_u64(255u64) catch err { return 8; };  // "ff" = 2 bytes
    print("hex count:  ") catch err { return 8; };
    print_u64(sink.count as u64) catch err { return 8; };
    print(" bytes\n") catch err { return 8; };

    // ── Section 9: Dynamic dispatch pipeline ─────────────────────────────────
    // Write the same content through a *Writer pointing at different sinks.
    print("repeat:     ") catch err { return 9; };
    out3 := stdout();
    rw: *Writer = &out3;
    rw.write_repeat(42u8, 8usize) catch err { return 9; };  // '*' == 42
    rw.write_char(10u8) catch err { return 9; };

    // ── Section 10: Stderr output ────────────────────────────────────────────
    eprintln("[stderr ok]") catch err { return 10; };

    r2 := rule();
    if r2 != 0 { return r2; }

    println("done") catch err { return 11; };
    return 0;
}

main :: fn() -> i32 {
    return run();
}
