#import std.io;

#extern("raylib", "InitWindow")
InitWindow :: fn(width: i32, height: i32, title: *const u8);

#extern("raylib", "WindowShouldClose")
WindowShouldClose :: fn() -> bool;

#extern("raylib", "BeginDrawing")
BeginDrawing :: fn();

#extern("raylib", "EndDrawing")
EndDrawing :: fn();

#extern("raylib", "CloseWindow")
CloseWindow :: fn();

main :: fn() -> i16 {
    InitWindow(800, 450, "Hello World".ptr);


    while !WindowShouldClose() {
        BeginDrawing();
        EndDrawing();
    }

    CloseWindow();
    return 0;
}
