// std.c вЂ” C ABI primitive types, for clearer `#extern` FFI declarations.
//
// These are transparent aliases (interchangeable with the underlying K2 type),
// sized for the C ABI on 64-bit Windows (LLP64: `long` is 32-bit, `size_t` is
// 64-bit). Using them documents intent and eases future cross-platform sizing.
//
//   #import std.c.{ c_int, c_char, c_size_t };
//
//   #extern("msvcrt", "strlen")
//   strlen :: fn(s: [*]const c_char) -> c_size_t;
//
//   #extern("msvcrt", "abs")
//   abs :: fn(x: c_int) -> c_int;

// в”Ђв”Ђ integer types в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

pub c_char      :: i8;       // `char` (treated as signed here)
pub c_schar     :: i8;       // `signed char`
pub c_uchar     :: u8;       // `unsigned char`
pub c_short     :: i16;      // `short`
pub c_ushort    :: u16;      // `unsigned short`
pub c_int       :: i32;      // `int`
pub c_uint      :: u32;      // `unsigned int`
pub c_long      :: i32;      // `long`   (LLP64: 32-bit on Windows)
pub c_ulong     :: u32;      // `unsigned long`
pub c_longlong  :: i64;      // `long long`
pub c_ulonglong :: u64;      // `unsigned long long`

// в”Ђв”Ђ sizes & pointers в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

pub c_size_t    :: usize;    // `size_t`
pub c_ssize_t   :: isize;    // `ssize_t` / `ptrdiff_t`
pub c_intptr    :: isize;    // `intptr_t`
pub c_uintptr   :: usize;    // `uintptr_t`
pub c_voidptr   :: usize;    // `void*` as a raw address (K2 has no void pointer)

// в”Ђв”Ђ floating point в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

pub c_float     :: f32;      // `float`
pub c_double    :: f64;      // `double`

// в”Ђв”Ђ other в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

pub c_bool      :: bool;     // C99 `_Bool`
pub c_string    :: [*]const u8;  // `const char*` (NUL-terminated)
