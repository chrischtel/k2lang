// std.build — K2's integrated build system.
//
// A project's `build.k2` defines `build :: fn(b: Build)`. `k2 build` runs it
// inside the comptime VM; each builder call invokes a `__build_*` compiler
// intrinsic that records into the driver's build plan. After `build` returns,
// the driver compiles + links each declared artifact (via the driver and the
// k2lnk linker).
//
//   #import std.build.{ Build, Artifact };
//
//   build :: fn(b: Build) {
//       b.workspace("my-game");
//       b.out_root("bin");
//
//       game := b.executable("game", "src/main.k2");
//       game.release_fast();
//       game.windowed();                 // GUI app: no console window
//       game.link("raylib");
//       game.lib_path("vendor/raylib/lib");
//       game.stack_size(8 * 1024 * 1024);
//       game.version("1.0.0");
//       game.install();
//
//       if b.option("trace") { game.define("TRACE", "1"); }
//
//       b.run_step("run", game);
//       b.default(game);
//       b.summary();
//   }
//
// Handles (`Build`, `Artifact`) are tiny value structs carrying an id; all build
// state lives in the compiler. See docs/10_build_system.md for the full design.

// ── Handles ─────────────────────────────────────────────────────────────────

pub Build    :: struct { id: i32 }
pub Artifact :: struct { id: i32 }

// ── Enums (public API) ──────────────────────────────────────────────────────

pub Optimize  :: enum { debug, release_safe, release_fast, release_small }
pub Subsystem :: enum { console, windows }

// Artifact-kind codes passed to __build_artifact:
//   0 executable · 1 shared_library (.dll) · 2 static_library (.lib) · 3 object

// ── Artifact declarations ─────────────────────────────────────────────────────

// Declare an executable with entry source `root`.
pub executable :: fn(self: Build, name: []const u8, root: []const u8) -> Artifact {
    return .{ __build_artifact(name, root, 0) };
}

// Declare a shared library (.dll).
pub shared :: fn(self: Build, name: []const u8, root: []const u8) -> Artifact {
    return .{ __build_artifact(name, root, 1) };
}

// Declare a static library (.lib).
pub static :: fn(self: Build, name: []const u8, root: []const u8) -> Artifact {
    return .{ __build_artifact(name, root, 2) };
}

// Declare an object file (.o), no link step.
pub object :: fn(self: Build, name: []const u8, root: []const u8) -> Artifact {
    return .{ __build_artifact(name, root, 3) };
}

// ── Optimization ──────────────────────────────────────────────────────────────

pub optimize :: fn(self: Artifact, level: Optimize) {
    match level {
        .debug         => { __build_opt(self.id, 0); }
        .release_safe  => { __build_opt(self.id, 1); }
        .release_fast  => { __build_opt(self.id, 2); }
        .release_small => { __build_opt(self.id, 3); }
    }
}

// Shorthands — `game.release_fast()` reads nicer than `game.optimize(.release_fast)`.
pub debug         :: fn(self: Artifact) { __build_opt(self.id, 0); }
pub release_safe  :: fn(self: Artifact) { __build_opt(self.id, 1); }
pub release_fast  :: fn(self: Artifact) { __build_opt(self.id, 2); }
pub release       :: fn(self: Artifact) { __build_opt(self.id, 2); } // alias for release_fast
pub release_small :: fn(self: Artifact) { __build_opt(self.id, 3); }

// ── Linking ───────────────────────────────────────────────────────────────────

// Link a system / import library by name (no extension): "raylib", "user32".
// Call it once per library.
pub link :: fn(self: Artifact, lib: []const u8) {
    __build_link(self.id, lib);
}

// `system_library` is a readability alias for `link` (matches the source directive).
pub system_library :: fn(self: Artifact, name: []const u8) {
    __build_link(self.id, name);
}

// Add a library search directory.
pub lib_path :: fn(self: Artifact, dir: []const u8) {
    __build_libpath(self.id, dir);
}

// Pass a raw flag straight to the linker (escape hatch), e.g. "/DEBUG".
pub link_flag :: fn(self: Artifact, flag: []const u8) {
    __build_linkflag(self.id, flag);
}

// Link the C runtime. Needed when linking a C library that was built against
// the CRT (e.g. a static raylib.lib calls malloc/free and the compiler's
// security/stack-check helpers, which K2's CRT-less link doesn't provide).
// Pulls in the UCRT (ucrt.lib: malloc/free/…) and VC runtime (vcruntime.lib:
// __chkstk, __report_rangecheckfailure, …). The compiler adds the matching
// search paths automatically (configured via --windows-sdk-lib-path /
// --msvc-lib-path at k2's own build time).
pub link_libc :: fn(self: Artifact) {
    __build_link(self.id, "ucrt");
    __build_link(self.id, "vcruntime");
}

// How C libraries are linked. `.dynamic` (the default) links the platform's
// import/shared library and you ship the runtime library (see `runtime_file`).
// `.static` links the archive and auto-links the C runtime (a static C lib
// brings its code but not the CRT it depends on). The library NAME you pass to
// `link()` stays the same either way — only the search path + this mode differ,
// which keeps a build.k2 portable across static/dynamic and (later) platforms.
pub LinkMode :: enum { dynamic, static }

pub link_mode :: fn(self: Artifact, mode: LinkMode) {
    match mode {
        .dynamic => { __build_linkmode(self.id, 0); }
        .static  => { __build_linkmode(self.id, 1); }
    }
}

// Shorthands: `app.dynamic()` / `app.static_link()`.
pub dynamic :: fn(self: Artifact) { __build_linkmode(self.id, 0); }
pub static_link :: fn(self: Artifact) { __build_linkmode(self.id, 1); }

// Copy a runtime dependency (e.g. a `.dll`) next to the output after building,
// so a dynamically-linked program runs without manually shipping its DLLs.
pub runtime_file :: fn(self: Artifact, path: []const u8) {
    __build_runtimefile(self.id, path);
}

// ── Executable settings ─────────────────────────────────────────────────────────

// Choose the PE subsystem (console window or not).
pub subsystem :: fn(self: Artifact, sub: Subsystem) {
    match sub {
        .console => { __build_subsystem(self.id, 0); }
        .windows => { __build_subsystem(self.id, 1); }
    }
}

// A console app (terminal window). This is the default.
pub console :: fn(self: Artifact) { __build_subsystem(self.id, 0); }

// A windowed/GUI app — no console window pops up (what a game wants).
pub windowed :: fn(self: Artifact) { __build_subsystem(self.id, 1); }

// Override the linker entry symbol (default: the runtime's `mainCRTStartup`).
pub entry :: fn(self: Artifact, symbol: []const u8) {
    __build_entry(self.id, symbol);
}

// Reserve a custom stack size (bytes).
pub stack_size :: fn(self: Artifact, bytes: u64) {
    __build_stack(self.id, bytes as i64);
}

// ── Output ────────────────────────────────────────────────────────────────────

// Set the output path explicitly (default: derived from the name).
pub output :: fn(self: Artifact, path: []const u8) {
    __build_output(self.id, path);
}

// Put this artifact's output in `dir` (overrides the workspace out_root).
pub out_dir :: fn(self: Artifact, dir: []const u8) {
    __build_outdir(self.id, dir);
}

// ── Metadata ────────────────────────────────────────────────────────────────────

// Record a semantic version (shown in the build summary).
pub version :: fn(self: Artifact, v: []const u8) {
    __build_version(self.id, v);
}

// A human-readable description (shown by `--list`).
pub description :: fn(self: Artifact, text: []const u8) {
    __build_desc(self.id, text);
}

// Mark this artifact for installation (flagged in the build summary).
pub install :: fn(self: Artifact) {
    __build_install(self.id);
}

// Inject a comptime constant into this build (a `#provided`-style override).
pub define :: fn(self: Artifact, key: []const u8, val: []const u8) {
    __build_define(self.id, key, val);
}

// ── Dependencies ──────────────────────────────────────────────────────────────

// A dependency resolved from a local directory (its own build.k2 runs sandboxed).
pub require_path :: fn(self: Build, name: []const u8, dir: []const u8) -> i32 {
    return __build_require(name, dir, 0);
}

// A dependency fetched from git (revision pinning lands with the fetcher).
pub require_git :: fn(self: Build, name: []const u8, url: []const u8) -> i32 {
    return __build_require(name, url, 1);
}

// Record that `self` depends on dependency `dep` (the id from require_*).
pub depend :: fn(self: Artifact, dep: i32) {
    __build_depend(self.id, dep);
}

// ── Workspace ───────────────────────────────────────────────────────────────────

// Name the workspace (shown in the build summary).
pub workspace :: fn(self: Build, name: []const u8) {
    __build_workspace(name);
}

// Default output directory for every artifact (a per-artifact `out_dir` wins).
pub out_root :: fn(self: Build, dir: []const u8) {
    __build_outroot(dir);
}

// Print a summary of every artifact after the build.
pub summary :: fn(self: Build) {
    __build_summary(1);
}

// ── Build options (`k2 build -Dname` / `-Dname=value`) ───────────────────────────

// True if `-Dname` was passed on the command line.
pub option :: fn(self: Build, name: []const u8) -> bool {
    return __build_optionflag(name) != 0;
}

// The value of `-Dname=value`, or `default` if not given.
pub option_str :: fn(self: Build, name: []const u8, default: []const u8) -> []const u8 {
    return __build_optionstr(name, default);
}

// ── Steps & default ───────────────────────────────────────────────────────────

// A run step: `k2 build <name>` builds `target`, then runs it.
pub run_step :: fn(self: Build, name: []const u8, target: Artifact) {
    __build_run(name, target.id);
}

// A test step: build + run every test under `dir`.
pub test_dir :: fn(self: Build, name: []const u8, dir: []const u8) {
    __build_test(name, dir);
}

// Set which artifact bare `k2 build` produces.
pub default :: fn(self: Build, target: Artifact) {
    __build_default(target.id);
}
