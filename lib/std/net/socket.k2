// std.net.socket — a typed handle over a raw OS socket.
//
// `Socket` wraps a Winsock `SOCKET` and carries the operations that are common
// to every protocol: closing, half-close, and the socket options (timeouts,
// address reuse, non-blocking mode, broadcast). `tcp.k2` and `udp.k2` embed a
// `Socket` and add the protocol-specific verbs on top, so option handling lives
// in exactly one place.

#import std.net.os as os;
#import std.net.os.{NetError};
#import std.net.addr as addr;

// 1/0 for a bool — k2 has no if-expression and bools aren't matchable, and the
// socket options below all take a BOOL-as-int.
bint :: fn(b: bool) -> i32 { if b { return 1; } return 0; }

// A socket handle. `fd` is the raw Winsock `SOCKET`; `INVALID_SOCKET` means "no
// socket". Construct one with `tcp()` / `udp()`, or wrap an existing fd (e.g. the
// result of `accept`) with `from_fd`.
pub Socket :: struct {
    fd: usize

    // True unless the handle is the sentinel invalid socket.
    pub is_valid :: fn(self: *Self) -> bool { return self.fd != os::INVALID_SOCKET; }

    // Close the underlying OS socket. Safe to call on an invalid handle.
    pub close :: fn(self: *Self) {
        if self.fd != os::INVALID_SOCKET { ignored := os::sys_closesocket(self.fd); }
    }

    // Half-close one or both directions (`os::SHUT_RECV`/`SHUT_SEND`/`SHUT_BOTH`).
    pub shutdown :: fn(self: *Self, how: i32) -> void ! NetError {
        if os::sys_shutdown(self.fd, how) != 0 { fail .option_failed; }
        return;
    }

    // Set an integer-valued socket option (the common case: timeouts, BOOL flags).
    pub set_opt_int :: fn(self: *Self, level: i32, opt: i32, value: i32) -> void ! NetError {
        v: i32 = value;
        if os::sys_setsockopt(self.fd, level, opt, unsafe ((&v) as *const u8), 4) != 0 {
            fail .option_failed;
        }
        return;
    }

    // Allow binding to an address still in TIME_WAIT (servers should set this
    // before `bind`). `SO_REUSEADDR` takes a BOOL, i.e. a 0/1 int.
    pub set_reuse_addr :: fn(self: *Self, on: bool) -> void ! NetError {
        self.set_opt_int(os::SOL_SOCKET, os::SO_REUSEADDR, bint(on))?;
        return;
    }

    // Allow sending to a broadcast address (UDP).
    pub set_broadcast :: fn(self: *Self, on: bool) -> void ! NetError {
        self.set_opt_int(os::SOL_SOCKET, os::SO_BROADCAST, bint(on))?;
        return;
    }

    // Receive timeout in milliseconds (0 = block forever). After this, a blocking
    // `recv` fails instead of hanging — handy for "give up after N ms".
    pub set_recv_timeout :: fn(self: *Self, ms: i32) -> void ! NetError {
        self.set_opt_int(os::SOL_SOCKET, os::SO_RCVTIMEO, ms)?;
        return;
    }

    // Send timeout in milliseconds (0 = block forever).
    pub set_send_timeout :: fn(self: *Self, ms: i32) -> void ! NetError {
        self.set_opt_int(os::SOL_SOCKET, os::SO_SNDTIMEO, ms)?;
        return;
    }

    // Switch the socket between blocking (default) and non-blocking mode. In
    // non-blocking mode a call with no data ready fails with `would_block` rather
    // than waiting (check with `os::is_would_block()`).
    pub set_nonblocking :: fn(self: *Self, on: bool) -> void ! NetError {
        mode: u32 = 0u32;
        if on { mode = 1u32; }
        if os::sys_ioctlsocket(self.fd, os::FIONBIO, &mode) != 0 { fail .option_failed; }
        return;
    }

    // Bind the socket to a local address (server sockets, or a fixed UDP port).
    pub bind_to :: fn(self: *Self, sa: addr::SocketAddr) -> void ! NetError {
        raw := os::raw_from(sa);
        if os::sys_bind(self.fd, unsafe ((&raw) as *const u8), os::SOCKADDR_LEN as i32) != 0 {
            fail .bind_failed;
        }
        return;
    }

    // The address actually bound to this socket (resolves an OS-chosen ephemeral
    // port after `bind` to port 0).
    pub local_addr :: fn(self: *Self) -> addr::SocketAddr ! NetError {
        raw: os::RawSockaddr = .{ 0u16, 0u16, 0u32, 0u64 };
        len: i32 = os::SOCKADDR_LEN as i32;
        if os::sys_getsockname(self.fd, unsafe ((&raw) as *u8), &len) != 0 { fail .addr_failed; }
        return os::addr_from_raw(raw);
    }
}

// Wrap an already-open OS socket fd (e.g. from `accept`).
pub from_fd :: fn(fd: usize) -> Socket { return .{ fd }; }

// Create a fresh TCP (stream) socket.
pub tcp :: fn() -> Socket ! NetError {
    fd := os::sys_socket(os::AF_INET, os::SOCK_STREAM, os::IPPROTO_TCP);
    if fd == os::INVALID_SOCKET { fail .socket_failed; }
    return .{ fd };
}

// Create a fresh UDP (datagram) socket.
pub udp :: fn() -> Socket ! NetError {
    fd := os::sys_socket(os::AF_INET, os::SOCK_DGRAM, os::IPPROTO_UDP);
    if fd == os::INVALID_SOCKET { fail .socket_failed; }
    return .{ fd };
}
