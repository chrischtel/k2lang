// SPDX-License-Identifier: Apache-2.0
// std.net.os — the raw OS networking layer (Winsock2 / ws2_32.dll).
//
// This is the foundation the rest of std.net is built on: the raw `#extern`
// bindings, the protocol constants, the `sockaddr_in` wire struct, the shared
// `NetError`, and the conversions between `std.net.addr` types and the wire
// format. Nothing here is "friendly" — `socket.k2`, `tcp.k2`, and `udp.k2` wrap
// it into typed handles. Reach for this layer directly only when you need an
// option or call the higher layers don't expose.
//
// The k2 name of each binding is decoupled from the C symbol (the `#extern`
// 2nd arg is the real link name), so every raw call keeps a `sys_` prefix and
// the idiomatic names stay free for the wrappers above.

#import std.net.addr as addr;

// ── Winsock2 bindings ────────────────────────────────────────────────────────
#extern("ws2_32", "WSAStartup") pub sys_wsa_startup  :: fn(version: u16, data: *u8) -> i32;
#extern("ws2_32", "WSACleanup") pub sys_wsa_cleanup  :: fn() -> i32;
#extern("ws2_32", "WSAGetLastError") pub sys_wsa_lasterr :: fn() -> i32;
#extern("ws2_32", "socket") pub sys_socket       :: fn(af: i32, kind: i32, proto: i32) -> usize;
#extern("ws2_32", "closesocket") pub sys_closesocket  :: fn(s: usize) -> i32;
#extern("ws2_32", "connect") pub sys_connect      :: fn(s: usize, name: *const u8, namelen: i32) -> i32;
#extern("ws2_32", "bind") pub sys_bind         :: fn(s: usize, name: *const u8, namelen: i32) -> i32;
#extern("ws2_32", "listen") pub sys_listen       :: fn(s: usize, backlog: i32) -> i32;
#extern("ws2_32", "accept") pub sys_accept       :: fn(s: usize, name: ?*u8, namelen: ?*i32) -> usize;
#extern("ws2_32", "send") pub sys_send         :: fn(s: usize, buf: *const u8, len: i32, flags: i32) -> i32;
#extern("ws2_32", "recv") pub sys_recv         :: fn(s: usize, buf: *u8, len: i32, flags: i32) -> i32;
#extern("ws2_32", "sendto") pub sys_sendto       :: fn(s: usize, buf: *const u8, len: i32, flags: i32, to: *const u8, tolen: i32) -> i32;
#extern("ws2_32", "recvfrom") pub sys_recvfrom     :: fn(s: usize, buf: *u8, len: i32, flags: i32, from: *u8, fromlen: *i32) -> i32;
#extern("ws2_32", "setsockopt") pub sys_setsockopt   :: fn(s: usize, level: i32, opt: i32, val: *const u8, len: i32) -> i32;
#extern("ws2_32", "getsockname") pub sys_getsockname  :: fn(s: usize, name: *u8, namelen: *i32) -> i32;
#extern("ws2_32", "ioctlsocket") pub sys_ioctlsocket  :: fn(s: usize, cmd: u32, argp: *u32) -> i32;
#extern("ws2_32", "shutdown") pub sys_shutdown     :: fn(s: usize, how: i32) -> i32;
#extern("ws2_32", "htons") pub sys_htons        :: fn(x: u16) -> u16;
#extern("ws2_32", "ntohs") pub sys_ntohs        :: fn(x: u16) -> u16;

// ── Protocol constants ───────────────────────────────────────────────────────
pub AF_INET        :: 2;
pub SOCK_STREAM    :: 1;        // TCP
pub SOCK_DGRAM     :: 2;        // UDP
pub IPPROTO_TCP    :: 6;
pub IPPROTO_UDP    :: 17;
pub INVALID_SOCKET :: 0xFFFFFFFFFFFFFFFF;   // (SOCKET)(~0)
pub SOCKET_ERROR   :: -1;
pub SOCKADDR_LEN   :: 16;       // sizeof(sockaddr_in)

// setsockopt levels / options
pub SOL_SOCKET     :: 0xFFFF;
pub SO_REUSEADDR   :: 0x0004;
pub SO_BROADCAST   :: 0x0020;
pub SO_RCVTIMEO    :: 0x1006;   // receive timeout, DWORD milliseconds
pub SO_SNDTIMEO    :: 0x1005;   // send timeout, DWORD milliseconds
pub TCP_NODELAY    :: 0x0001;   // at level IPPROTO_TCP — disable Nagle

// ioctlsocket command: non-blocking mode (argp != 0 → non-blocking)
pub FIONBIO        :: 0x8004667Eu32;

// shutdown() directions
pub SHUT_RECV      :: 0;        // SD_RECEIVE
pub SHUT_SEND      :: 1;        // SD_SEND
pub SHUT_BOTH      :: 2;        // SD_BOTH

// WSAGetLastError codes we care about
pub WSAEWOULDBLOCK :: 10035;

// ── Shared error type ────────────────────────────────────────────────────────
// Every layer of std.net fails with this. Where a specific syscall failed is in
// the variant name; the numeric Winsock code is available via `last_error()`.
pub NetError :: errors {
    startup_failed,   // WSAStartup
    socket_failed,    // socket()
    connect_failed,   // connect()
    bind_failed,      // bind()
    listen_failed,    // listen()
    accept_failed,    // accept()
    send_failed,      // send()/sendto()
    recv_failed,      // recv()/recvfrom()
    option_failed,    // setsockopt()/ioctlsocket()
    addr_failed,      // getsockname()
    would_block,      // a non-blocking call had no data ready
    closed,           // peer closed the connection
}

// ── The wire address: `sockaddr_in` (16 bytes) ───────────────────────────────
// family(2) port(2, network order) addr(4, network order) zero(8).
pub RawSockaddr :: struct { family: u16, port: u16, addr: u32, zero: u64 }

// Build the wire form from a friendly `SocketAddr` (host order → network order).
pub raw_from :: fn(sa: addr::SocketAddr) -> RawSockaddr {
    return .{ AF_INET as u16, sys_htons(sa.port), sa.ip.to_net(), 0u64 };
}

// Decode the wire form back to a friendly `SocketAddr` (network → host order).
pub addr_from_raw :: fn(r: RawSockaddr) -> addr::SocketAddr {
    return .{ addr::from_net(r.addr), sys_ntohs(r.port) };
}

// ── Library lifecycle ────────────────────────────────────────────────────────
// Initialise Winsock — must be called once before any socket call in a process.
pub init :: fn() -> void ! NetError {
    data: [512]u8 = .{};                 // WSADATA
    if sys_wsa_startup(0x0202u16, &data[0]) != 0 { fail .startup_failed; }
    return;
}

// Tear Winsock down (optional, at process exit).
pub cleanup :: fn() { ignored := sys_wsa_cleanup(); }

// The last Winsock error code on this thread (`WSAGetLastError`).
pub last_error :: fn() -> i32 { return sys_wsa_lasterr(); }

// True if `WSAGetLastError()` indicates a non-blocking call would have blocked.
pub is_would_block :: fn() -> bool { return sys_wsa_lasterr() == WSAEWOULDBLOCK; }