// std.path — filesystem path manipulation (pure string ops, no I/O).
//
// Paths are plain `[]const u8` byte slices. Both `/` and `\` are treated as
// separators (so paths from any source parse correctly), while `join` writes
// the platform separator `SEP` (`\` on Windows). The query functions
// (`basename`, `dirname`, `extension`, `stem`) allocate nothing — they return
// sub-slices of their input. The builders (`join`, `with_extension`) take an
// `*Arena`.
//
//   base := path::basename("src\\std\\io.k2");     // "io.k2"
//   dir  := path::dirname ("src\\std\\io.k2");      // "src\std"
//   ext  := path::extension("io.k2");               // ".k2"  (with the dot)
//   stem := path::stem("io.k2");                    // "io"
//   full := path::join(&a, "src\\std", "io.k2");    // "src\std\io.k2"
//
// Invariant: `basename(p)` == `stem(p)` ++ `extension(p)`.

#import std.heap.{ Arena };
#import std.strings as strings;

// Platform path separator written by `join` / `with_extension`.
pub SEP :: 92u8;   // '\'

// True for either separator byte, so paths using `/` or `\` both parse.
pub is_sep :: fn(c: u8) -> bool { return c == 47u8 || c == 92u8; }   // '/' or '\'

// The final component of `p` (everything after the last separator). For a path
// with no separator, that's `p` itself; for a trailing separator, "".
pub basename :: fn(p: []const u8) -> []const u8 {
    i: usize = p.len;
    while i > 0usize {
        if is_sep(p[i - 1usize]) { return p[i..p.len]; }
        i = i - 1usize;
    }
    return p;
}

// Everything up to (but not including) the last separator, with any trailing
// separators trimmed. "." when `p` has no separator; the root ("\" or "/") when
// the only separator is a leading one.
pub dirname :: fn(p: []const u8) -> []const u8 {
    i: usize = p.len;
    while i > 0usize {
        if is_sep(p[i - 1usize]) {
            j: usize = i - 1usize;
            while j > 0usize {
                if is_sep(p[j - 1usize]) { j = j - 1usize; } else { break; }
            }
            if j == 0usize { return p[0..1usize]; }   // a rooted path like "\a"
            return p[0..j];
        }
        i = i - 1usize;
    }
    return ".";
}

// `dirname`, spelled the way most people say it.
pub parent :: fn(p: []const u8) -> []const u8 { return dirname(p); }

// The extension INCLUDING the leading dot (".txt"), or "" when there is none.
// A dotfile with no other dot (".gitignore") has no extension.
pub extension :: fn(p: []const u8) -> []const u8 {
    b := basename(p);
    i: usize = b.len;
    while i > 0usize {
        c := b[i - 1usize];
        if c == 46u8 {                                 // '.'
            if i - 1usize == 0usize { return ""; }     // leading-dot file
            return b[(i - 1usize)..b.len];
        }
        i = i - 1usize;
    }
    return "";
}

// The basename with its extension removed: `basename` minus `extension`.
pub stem :: fn(p: []const u8) -> []const u8 {
    b := basename(p);
    e := extension(p);
    return b[0..(b.len - e.len)];
}

// True if `p` starts with a separator, a `\\` UNC prefix, or a `X:` drive.
pub is_absolute :: fn(p: []const u8) -> bool {
    if p.len == 0usize { return false; }
    if is_sep(p[0]) { return true; }
    if p.len >= 2usize {
        if p[1] == 58u8 { return true; }               // ':' → drive letter
    }
    return false;
}

pub is_relative :: fn(p: []const u8) -> bool { return !is_absolute(p); }

// True if `p`'s extension equals `want` (a leading dot in `want` is optional, so
// both `has_extension(p, "k2")` and `has_extension(p, ".k2")` work).
pub has_extension :: fn(p: []const u8, want: []const u8) -> bool {
    e := extension(p);
    if want.len > 0usize {
        if want[0] == 46u8 { return strings::str_eq(e, want); }
    }
    // `want` has no leading dot — compare against the extension sans dot.
    if e.len == 0usize { return want.len == 0usize; }
    return strings::str_eq(e[1usize..e.len], want);
}

// ── Builders (need an arena) ─────────────────────────────────────────────────

// Join two path segments with a single `SEP`. Trailing separators on `x` and
// leading ones on `y` are collapsed. An absolute `y` replaces `x` entirely.
pub join :: fn(a: *Arena, x: []const u8, y: []const u8) -> []const u8 {
    if x.len == 0usize { return strings::str_dup(a, y); }
    if y.len == 0usize { return strings::str_dup(a, x); }
    if is_absolute(y) { return strings::str_dup(a, y); }

    xe: usize = x.len;
    while xe > 0usize {
        if is_sep(x[xe - 1usize]) { xe = xe - 1usize; } else { break; }
    }
    ys: usize = 0usize;
    while ys < y.len {
        if is_sep(y[ys]) { ys = ys + 1usize; } else { break; }
    }

    sb := strings::builder(a);
    strings::append(&sb, x[0..xe]);
    strings::append_byte(&sb, SEP);
    strings::append(&sb, y[ys..y.len]);
    return strings::str(&sb);
}

// Join three segments: `join(a, join(a, x, y), z)`.
pub join3 :: fn(a: *Arena, x: []const u8, y: []const u8, z: []const u8) -> []const u8 {
    return join(a, join(a, x, y), z);
}

// `p` with its extension replaced by `new_ext` (a leading dot in `new_ext` is
// optional). Removing the extension is `with_extension(a, p, "")`.
pub with_extension :: fn(a: *Arena, p: []const u8, new_ext: []const u8) -> []const u8 {
    e := extension(p);
    base := p[0..(p.len - e.len)];
    sb := strings::builder(a);
    strings::append(&sb, base);
    if new_ext.len > 0usize {
        if new_ext[0] != 46u8 { strings::append_byte(&sb, 46u8); }
        strings::append(&sb, new_ext);
    }
    return strings::str(&sb);
}
