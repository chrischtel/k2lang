// std.heap — runtime dynamic memory for K2.
//
// A bump arena: allocation is a pointer bump inside the current region.
//
// Why this is fast: VirtualAlloc is a syscall (~µs), but it runs at most once
// per *chunk* (or page, for a reserved arena) — never per allocation. A 16-byte
// alloc is a few instructions and zero syscalls. `reset`/`restore` reuse the
// memory, so steady-state allocation is entirely syscall-free.
//
// Backings:
//   make()        growable — reserves 64 KiB chunks from the OS on demand
//   reserve(max)  reserves `max` bytes of address space up front (cheap — no
//                 physical memory) and commits pages lazily as the bump pointer
//                 advances. One contiguous region; allocations never fail until
//                 `max` is exhausted. Ideal for building one large output.
//   fixed(buf)    over a caller []u8 (stack/static) — zero syscalls, cannot grow
//
// Allocation:
//   alloc_bytes / try_alloc_bytes   raw `[]u8`
//   alloc / try_alloc               typed `[]T`
//   alloc_one(T)                    a single `*T`
//   dupe(T, src)                    a copy of `src` owned by the arena
// (`try_*` return `! MemError`; the others abort on exhaustion.)
//
// Reuse:
//   reset()              rewind to empty, keep memory for reuse
//   mark() / restore(m)  save a watermark and rewind to it (nested scratch)
//   deinit()             return everything to the OS
//
// Region passing: hand an `*Arena` to a callee so it allocates into *your*
// region; the data may then outlive the callee and be returned to you.
//
//   build :: fn(into: *Arena, n: usize) -> []u8 {
//       buf := into.alloc_bytes(n);     // belongs to the caller's region
//       return buf;                     // safe — `into` outlives us
//   }

#import std.ptr.{ align_up };

// ── Win32 ─────────────────────────────────────────────────────────────────

#extern("kernel32", "VirtualAlloc")
VirtualAlloc :: fn(addr: usize, size: usize, alloc_type: u32, protect: u32) -> usize;

#extern("kernel32", "VirtualFree")
VirtualFree :: fn(addr: usize, size: usize, free_type: u32) -> bool;

MEM_COMMIT     :: 0x00001000u32;
MEM_RESERVE    :: 0x00002000u32;
MEM_RELEASE    :: 0x00008000u32;
PAGE_READWRITE :: 0x00000004u32;

// ── Tunables ──────────────────────────────────────────────────────────────

// Default chunk payload (64 KiB) for a growable arena. Allocations larger than
// this get their own exact-fit chunk.
DEFAULT_CHUNK :: 65536usize;

// Bytes reserved at the base of every chunk for its `Chunk` header. sizeof
// (Chunk) is 32; already a multiple of the 16-byte max alignment, so the data
// area that follows is aligned.
CHUNK_HEADER :: 32usize;

// Every allocation is aligned to 16 bytes — the strictest alignment any K2
// scalar/pointer needs.
ALIGN :: 16usize;

// OS page size (x64). Reserved arenas commit memory a page at a time.
PAGE :: 4096usize;

// Backing modes (Arena.mode).
ARENA_FIXED    :: 0u8;       // over a caller buffer; never touches the OS
ARENA_CHUNKED  :: 1u8;       // grows by reserving fresh 64 KiB chunks
ARENA_RESERVED :: 2u8;       // one up-front reservation, pages committed lazily

// ── Types ─────────────────────────────────────────────────────────────────

pub MemError :: errors {
    out_of_memory,      // backing exhausted (VirtualAlloc failed, or a fixed/reserved cap is full)
}

// Chunk header, stored in-place at the base of each chunk's region. `cap` bytes
// of usable storage follow `CHUNK_HEADER` bytes later. `committed` tracks how
// much of that payload is physically backed (== cap for chunked/fixed chunks;
// grows on demand for a reserved arena). `next` chains chunks in allocation
// order — for reset-reuse and bulk free.
Chunk :: struct {
    next:      usize,
    cap:       usize,
    committed: usize,
    used:      usize,
}

// A bump arena. `first` is the oldest chunk (reset/deinit start there), `head`
// the current bump chunk, `mode` the backing (see ARENA_* above).
pub Arena :: struct {
    first: usize,
    head:  usize,
    mode:  u8,
}

// A saved bump position for `restore` — nested scratch scopes within an arena.
pub Mark :: struct {
    chunk: usize,
    used:  usize,
}

// ── Constructors ──────────────────────────────────────────────────────────

// A fresh growable arena. No memory is reserved until the first allocation.
pub make :: fn() -> Arena {
    return .{ 0usize, 0usize, ARENA_CHUNKED };
}

// Reserve `max` bytes of address space up front (no physical memory yet) and
// commit pages on demand. One contiguous region; pointers never move.
pub reserve :: fn(max: usize) -> Arena {
    base := VirtualAlloc(0usize, CHUNK_HEADER + max, MEM_RESERVE, PAGE_READWRITE);
    if base == 0usize { return .{ 0usize, 0usize, ARENA_RESERVED }; }
    // Commit the first page so the header (and a little payload) is writable.
    if VirtualAlloc(base, PAGE, MEM_COMMIT, PAGE_READWRITE) == 0usize {
        ignored := VirtualFree(base, 0usize, MEM_RELEASE);
        return .{ 0usize, 0usize, ARENA_RESERVED };
    }
    c := unsafe core::ptr_from_int(*Chunk, base);
    c.next = 0usize;
    c.cap = max;
    init := PAGE - CHUNK_HEADER;
    if init > max { init = max; }
    c.committed = init;
    c.used = 0usize;
    return .{ base, base, ARENA_RESERVED };
}

// An arena over a caller-provided buffer (stack or static). No syscalls; cannot
// grow. The buffer must outlive the arena.
pub fixed :: fn(buf: []u8) -> Arena {
    if buf.len < CHUNK_HEADER { return .{ 0usize, 0usize, ARENA_FIXED }; }
    base := unsafe (buf.ptr as usize);
    c := unsafe core::ptr_from_int(*Chunk, base);
    c.next = 0usize;
    cap := buf.len - CHUNK_HEADER;
    c.cap = cap;
    c.committed = cap;
    c.used = 0usize;
    return .{ base, base, ARENA_FIXED };
}

// ── Core bump ─────────────────────────────────────────────────────────────

// Commit enough pages so `need_payload` bytes of `c`'s payload are backed.
// Only ever extends a reserved arena (chunked/fixed chunks are fully committed).
commit_more :: fn(chunk_addr: usize, c: *Chunk, need_payload: usize) -> bool {
    want := align_up(need_payload, PAGE);
    if want > c.cap { want = c.cap; }
    if VirtualAlloc(chunk_addr, CHUNK_HEADER + want, MEM_COMMIT, PAGE_READWRITE) == 0usize {
        return false;
    }
    c.committed = want;
    return true;
}

// Reserve `need` aligned bytes and return their address, or null when exhausted.
carve :: fn(self: *Arena, need: usize) -> ?usize {
    if self.head != 0usize {
        c := unsafe core::ptr_from_int(*Chunk, self.head);
        data := self.head + CHUNK_HEADER;
        aligned := align_up(data + c.used, ALIGN);
        if aligned + need <= data + c.cap {
            np := (aligned + need) - data;
            if np > c.committed {
                if !commit_more(self.head, c, np) { return null; }
            }
            c.used = np;
            return aligned;
        }
        // Current chunk full. After reset/restore, the next chunk is reusable.
        if c.next != 0usize {
            nx := unsafe core::ptr_from_int(*Chunk, c.next);
            nd := c.next + CHUNK_HEADER;
            na := align_up(nd, ALIGN);
            if na + need <= nd + nx.cap {
                np2 := (na + need) - nd;
                if np2 > nx.committed {
                    if !commit_more(c.next, nx, np2) { return null; }
                }
                nx.used = np2;
                self.head = c.next;
                return na;
            }
        }
    }

    // A new chunk is only possible for a growable arena.
    if self.mode != ARENA_CHUNKED { return null; }
    cap := DEFAULT_CHUNK;
    if need + ALIGN > cap { cap = need + ALIGN; }
    raw := VirtualAlloc(0usize, CHUNK_HEADER + cap, MEM_COMMIT | MEM_RESERVE, PAGE_READWRITE);
    if raw == 0usize { return null; }

    nc := unsafe core::ptr_from_int(*Chunk, raw);
    nc.cap = cap;
    nc.committed = cap;
    data2 := raw + CHUNK_HEADER;
    aligned2 := align_up(data2, ALIGN);
    nc.used = (aligned2 + need) - data2;

    if self.head != 0usize {
        hc := unsafe core::ptr_from_int(*Chunk, self.head);
        nc.next = hc.next;
        hc.next = raw;
    } else {
        nc.next = 0usize;
        self.first = raw;
    }
    self.head = raw;
    return aligned2;
}

// ── Byte allocation ───────────────────────────────────────────────────────

// Allocate `n` bytes. Aborts on exhaustion.
pub alloc_bytes :: fn(self: *Arena, n: usize) -> []u8 {
    addr := carve(self, n);
    if addr == null { core::panic("std.heap: out of memory"); }
    p := unsafe core::ptr_from_int(*u8, addr!!);
    return unsafe core::slice_raw(u8, p, n);
}

// Allocate `n` bytes, returning `MemError.out_of_memory` instead of aborting.
pub try_alloc_bytes :: fn(self: *Arena, n: usize) -> []u8 ! MemError {
    addr := carve(self, n);
    if addr == null { fail .out_of_memory; }
    p := unsafe core::ptr_from_int(*u8, addr!!);
    return unsafe core::slice_raw(u8, p, n);
}

// ── Typed allocation ──────────────────────────────────────────────────────

// Allocate a `[]T` of `n` elements (16-byte aligned, which covers any T).
// Aborts on exhaustion. Call as `(&a).alloc(T, n)` or `alloc(T, &a, n)`.
pub alloc :: fn($T: type, self: *Arena, n: usize) -> []T {
    bytes := alloc_bytes(self, n * core::sizeof(T));
    tp := unsafe (bytes.ptr as *T);
    return unsafe core::slice_raw(T, tp, n);
}

// Fallible `alloc`. Call as `(&a).try_alloc(T, n)` or `try_alloc(T, &a, n)`.
pub try_alloc :: fn($T: type, self: *Arena, n: usize) -> []T ! MemError {
    bytes := try_alloc_bytes(self, n * core::sizeof(T))?;
    tp := unsafe (bytes.ptr as *T);
    return unsafe core::slice_raw(T, tp, n);
}

// Allocate a single `T` and return a pointer to it. Aborts on exhaustion.
// Call as `(&a).alloc_one(T)`.
pub alloc_one :: fn($T: type, self: *Arena) -> *T {
    bytes := alloc_bytes(self, core::sizeof(T));
    return unsafe (bytes.ptr as *T);
}

// Copy `src` into a fresh `[]T` owned by the arena. Aborts on exhaustion.
// Call as `(&a).dupe(T, src)`.
pub dupe :: fn($T: type, self: *Arena, src: []const T) -> []T {
    out := alloc(T, self, src.len);
    i := 0usize;
    while i < src.len {
        out[i] = src[i];
        i += 1usize;
    }
    return out;
}

// `new` / `new_slice` are the `zone` block's spelling of `alloc_one` / `alloc`.
// A `zone X: Arena {}` handle is an ordinary `Arena`, so these resolve by UFCS
// exactly like the rest of the API — `X.new(T)`, `X.new_slice(T, n)`. Kept so
// existing zone code (and docs/05) keep working after the allocators unified.
pub new :: fn($T: type, self: *Arena) -> *T {
    return alloc_one(T, self);
}

pub new_slice :: fn($T: type, self: *Arena, n: usize) -> []T {
    return alloc(T, self, n);
}

// ── Reuse & lifetime ──────────────────────────────────────────────────────

// Rewind the arena to empty, KEEPING its chunks for reuse. Everything allocated
// before is invalidated; no memory is returned to the OS, so the next round of
// allocations is syscall-free until it exceeds the retained capacity.
pub reset :: fn(self: *Arena) {
    cur := self.first;
    while cur != 0usize {
        c := unsafe core::ptr_from_int(*Chunk, cur);
        c.used = 0usize;
        cur = c.next;
    }
    self.head = self.first;
}

// Save the current bump position. Pair with `restore` for a nested scratch
// scope: allocate freely, then `restore(m)` frees it all at once (keeping the
// memory). Marks are only valid until the next `reset`/`deinit`.
pub mark :: fn(self: *Arena) -> Mark {
    if self.head == 0usize { return .{ 0usize, 0usize }; }
    c := unsafe core::ptr_from_int(*Chunk, self.head);
    return .{ self.head, c.used };
}

// Rewind to a previously saved `mark`. Everything allocated since is freed for
// reuse; chunks are kept.
pub restore :: fn(self: *Arena, m: Mark) {
    if m.chunk == 0usize {
        reset(self);
        return;
    }
    mc := unsafe core::ptr_from_int(*Chunk, m.chunk);
    cur := mc.next;
    while cur != 0usize {
        c := unsafe core::ptr_from_int(*Chunk, cur);
        c.used = 0usize;
        cur = c.next;
    }
    mc.used = m.used;
    self.head = m.chunk;
}

// Release the arena. Chunked and reserved arenas return their memory to the OS;
// a fixed arena (which doesn't own its buffer) is simply cleared. Reusable after.
pub deinit :: fn(self: *Arena) {
    if self.mode != ARENA_FIXED {
        cur := self.first;
        while cur != 0usize {
            c := unsafe core::ptr_from_int(*Chunk, cur);
            nx := c.next;
            ignored := VirtualFree(cur, 0usize, MEM_RELEASE);
            cur = nx;
        }
    }
    self.first = 0usize;
    self.head = 0usize;
}
