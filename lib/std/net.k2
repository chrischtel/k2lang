// std.net вЂ” TCP/UDP networking over Winsock2.
//
// This file is a thin convenience facade. The library is layered across a
// subdirectory module so each piece stays small and focused:
//
//   std.net.os     вЂ” raw ws2_32 bindings, constants, `NetError`, the wire addr
//   std.net.addr   вЂ” IpV4 / SocketAddr (parsing, formatting, `#derive(Eq)`)
//   std.net.socket вЂ” `Socket`: the typed handle + shared options (timeouts, вЂ¦)
//   std.net.tcp    вЂ” `TcpStream` / `TcpListener` (+ `send_all` / `recv_exact`)
//   std.net.udp    вЂ” `UdpSocket` (datagrams: `send_to` / `recv_from`)
//
// `net::init()` once per process, then either use the helpers here or import a
// submodule directly for its types:
//
//   net::init() catch e { return; };
//   s := net::connect(addr::socket_addr(addr::localhost(), 8080u16)) catch e { return; };
//   ignored := s.send_all("ping") catch e {};
//   net::shutdown();
//
// Types live in their submodule (`tcp::TcpStream`, `udp::UdpSocket`, вЂ¦) because
// the language doesn't re-export a type across modules; the constructors here
// hand those types back, so you only need the submodule import for annotations.

#import std.net.os as os;
#import std.net.os.{NetError};
#import std.net.addr as addr;
#import std.net.tcp as tcp;
#import std.net.udp as udp;

// в”Ђв”Ђ Library lifecycle в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

// Initialise Winsock вЂ” call once before any socket call.
pub init :: fn() -> void ! NetError { os::init()?; return; }

// Tear Winsock down (optional, at process exit).
pub shutdown :: fn() { os::cleanup(); }

// The last Winsock error code on this thread (`WSAGetLastError`), for diagnosing
// a `NetError`.
pub last_error :: fn() -> i32 { return os::last_error(); }

// в”Ђв”Ђ TCP convenience в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

// Connect to `sa` and return a ready `tcp::TcpStream` (client side).
pub connect :: fn(sa: addr::SocketAddr) -> tcp::TcpStream ! NetError {
    return tcp::connect(sa)?;
}

// Bind + listen on `sa`, returning a `tcp::TcpListener` (server side, backlog 16).
pub listen :: fn(sa: addr::SocketAddr) -> tcp::TcpListener ! NetError {
    return tcp::listen(sa)?;
}

// в”Ђв”Ђ UDP convenience в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

// A `udp::UdpSocket` bound to `sa`.
pub udp_bind :: fn(sa: addr::SocketAddr) -> udp::UdpSocket ! NetError {
    return udp::bind(sa)?;
}
