// Exercises std.heap so the module (and a typical user of it) stays compilable
// and lowerable. Covers all three backings (make / reserve / fixed), the byte
// and typed allocators (incl. alloc_one and dupe), and reuse (reset, mark/restore).

#import std.heap.{
    Arena, make, reserve, fixed,
    alloc, try_alloc, alloc_one, dupe, alloc_bytes, try_alloc_bytes,
    mark, restore, reset, deinit,
};

#entry
run :: fn() -> i32 {
    a := make();

    // typed allocation (generic alloc(T)) + a single value (alloc_one)
    xs := (&a).alloc(i32, 4usize);
    xs[0] = 7;
    one := (&a).alloc_one(i32);
    *one = 3;
    sum := xs[0] + *one;

    // dupe a slice into the arena
    src: [2]i32 = .{ 5, 6 };
    cp := (&a).dupe(i32, src[:]);
    sum = sum + cp[0] + cp[1];

    // a nested scratch scope via mark/restore, then a full reset
    m := (&a).mark();
    tmp := (&a).alloc_bytes(64usize);
    tmp[0] = 1u8;
    (&a).restore(m);
    (&a).reset();

    // fallible typed allocation (generic try_alloc(T))
    ys := (&a).try_alloc(i32, 2usize) catch e {
        (&a).deinit();
        return sum;
    };
    ys[0] = 2;
    sum = sum + ys[0];
    (&a).deinit();

    // reserve backing — lazy page commit
    r := reserve(65536usize);
    rb := (&r).alloc_bytes(100usize);
    rb[0] = 4u8;
    sum = sum + (rb[0] as i32);
    (&r).deinit();

    // fixed backing — over a stack buffer, no syscalls
    buf: [128]u8 = .{};
    f := fixed(buf[:]);
    fb := (&f).try_alloc_bytes(32usize) catch e { return sum; };
    fb[0] = 9u8;
    return sum + (fb[0] as i32);
}
