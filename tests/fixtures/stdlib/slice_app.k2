// Exercises std.slice's higher-order helpers (find/rfind/count_where/map_into,
// each taking a fn-pointer predicate). Returns 42 iff every check passes.
// (Plain element search/equality lives in std.mem; this module is the HOFs.)

#import std.slice;

is_neg :: fn(x: i32) -> bool { return x < 0; }
is_pos :: fn(x: i32) -> bool { return x > 0; }
inc    :: fn(x: i32) -> i32 { return x + 1; }

#entry
main :: fn() -> i32 {
    a: [5]i32 = .{ 3, -7, -2, 9, -1 };
    ok: bool = true;

    if slice::count_where(i32, a[:], is_neg) != 3usize { ok = false; }
    if slice::count_where(i32, a[:], is_pos) != 2usize { ok = false; }

    out: [5]i32 = .{ 0, 0, 0, 0, 0 };
    if slice::map_into(i32, i32, out[:], a[:], inc) != 5usize { ok = false; }
    if out[0] != 4 { ok = false; }

    fwd: bool = false;
    if slice::find(i32, a[:], is_neg) |i| { if i == 1usize { fwd = true; } }
    if !fwd { ok = false; }

    rev: bool = false;
    if slice::rfind(i32, a[:], is_neg) |i| { if i == 4usize { rev = true; } }
    if !rev { ok = false; }

    if ok { return 42; }
    return 0;
}
