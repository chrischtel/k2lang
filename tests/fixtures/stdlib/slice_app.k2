// Exercises std.slice: generic HOFs (find/count_where/any/all/map_into) and the
// byte-slice search helpers. Returns 42 iff every check passes.

#import std.slice;

is_neg :: fn(x: i32) -> bool { return x < 0; }
is_pos :: fn(x: i32) -> bool { return x > 0; }
inc    :: fn(x: i32) -> i32 { return x + 1; }

#entry
main :: fn() -> i32 {
    a: [5]i32 = .{ 3, -7, -2, 9, -1 };
    ok: bool = true;

    if slice::count_where(i32, a[:], is_neg) != 3usize { ok = false; }
    if slice::count_where(i32, a[:], is_pos) != 2usize { ok = false; }

    out: [5]i32 = .{ 0, 0, 0, 0, 0 };
    if slice::map_into(i32, i32, out[:], a[:], inc) != 5usize { ok = false; }
    if out[0] != 4 { ok = false; }

    found: bool = false;
    if slice::find(i32, a[:], is_neg) |i| { if i == 1usize { found = true; } }
    if !found { ok = false; }

    s: []const u8 = "hello.world.txt";
    if !slice::bytes_eql("abc", "abc") { ok = false; }
    if slice::bytes_eql("abc", "abd") { ok = false; }
    if !slice::starts_with(s, "hello") { ok = false; }
    if !slice::ends_with(s, ".txt") { ok = false; }
    if !slice::contains(s, '.') { ok = false; }
    last: bool = false;
    if slice::last_index_of(s, '.') |i| { if i == 11usize { last = true; } }
    if !last { ok = false; }

    if ok { return 42; }
    return 0;
}
