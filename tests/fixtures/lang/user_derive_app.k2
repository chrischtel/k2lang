// User-extensible derives: `#derive(Name)` for a name the compiler doesn't know
// is left for a user `#compiler` hook, which reads each declaration's requested
// derives from `core::compiler_decls()` (`Decl.derives`) and generates the impl.
// Here a user defines `#derive(Sum)`. Returns 42.
#import std.strings as str;
#import std.heap as heap;

// The user's derive generator: emit `sum_<Struct>` for every struct that opted in.
#compiler
derive_sum :: fn() -> []const u8 {
    a := heap::make();
    sb := str::builder(&a);
    for d in core::compiler_decls() {
        match d.derives {
            "Sum" => {
                sb.append("sum_"); sb.append(d.name);
                sb.append(" :: fn(p: "); sb.append(d.name);
                sb.append(") -> i32 { return 0");
                for f in d.fields { sb.append(" + p."); sb.append(f.name); }
                sb.append("; } ");
            }
            else => {}
        }
    }
    return sb.str();
}

#derive(Sum)
Point :: struct { x: i32, y: i32 }

Untagged :: struct { a: i32, b: i32 }   // not tagged → no sum_ generated

#entry
main :: fn() -> i32 {
    p: Point = .{ 30, 12 };
    return sum_Point(p);                 // generated by the user-defined derive
}
