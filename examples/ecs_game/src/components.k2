// components — the entity "kinds" and world dimensions shared across systems.

// What an entity is. The simulation is a tiny asteroids field: a fixed turret
// at the centre fires bullets at drifting asteroids, which split when hit.
pub Kind :: enum { None, Turret, Asteroid, Bullet }

// Playfield size, in world units. The renderer maps this onto an ASCII grid.
pub FIELD_W :: 80;
pub FIELD_H :: 30;

// Maximum live entities (component arrays are sized to this).
pub MAX_ENTITIES :: 256;
