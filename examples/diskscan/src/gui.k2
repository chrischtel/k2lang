// diskscan-gui — a native Win32 disk-usage browser with a treemap/heatmap.
//
// No toolkit, no dependencies: a window class, a message loop, and GDI drawing.
// Left pane: the current directory's children, biggest-first, with %, size, a
// bar and the name. Right pane: a squarified TREEMAP of the whole subtree,
// coloured by file type — the WinDirStat "block view", but flat and modern.
// Hover a block to inspect it; click to jump to its folder; Delete recycles.
//
//   ↑/↓ wheel  move        Enter / dblclick  open      Backspace  up
//   Tab        view mode   Delete            recycle    Esc        quit
//   mouse      hover+click on the treemap

#import std.heap.{ Arena, make, new_slice };
#import std.process;

#import scan.{ Stats, scan };
#import node.{ Node, make_node, finalize, live_children, mark_deleted };

// ── Win32 bindings ───────────────────────────────────────────────────────────
#extern("kernel32", "GetModuleHandleA") GetModuleHandleA :: fn(name: ?*const u8) -> usize;
#extern("user32", "LoadCursorA")        LoadCursorA :: fn(inst: usize, name: usize) -> usize;
#extern("user32", "RegisterClassExA")   RegisterClassExA :: fn(wc: *WNDCLASSEXA) -> u16;
#extern("user32", "CreateWindowExA")    CreateWindowExA :: fn(ex: u32, cls: *const u8, title: *const u8, style: u32, x: i32, y: i32, w: i32, h: i32, parent: usize, menu: usize, inst: usize, param: ?*void) -> usize;
#extern("user32", "ShowWindow")         ShowWindow :: fn(hwnd: usize, cmd: i32) -> bool;
#extern("user32", "UpdateWindow")       UpdateWindow :: fn(hwnd: usize) -> bool;
#extern("user32", "GetMessageA")        GetMessageA :: fn(msg: *MSG, hwnd: usize, min: u32, max: u32) -> i32;
#extern("user32", "TranslateMessage")   TranslateMessage :: fn(msg: *MSG) -> bool;
#extern("user32", "DispatchMessageA")   DispatchMessageA :: fn(msg: *MSG) -> isize;
#extern("user32", "DefWindowProcA")     DefWindowProcA :: fn(hwnd: usize, msg: u32, wp: usize, lp: isize) -> isize;
#extern("user32", "PostQuitMessage")    PostQuitMessage :: fn(code: i32);
#extern("user32", "BeginPaint")         BeginPaint :: fn(hwnd: usize, ps: *u8) -> usize;
#extern("user32", "EndPaint")           EndPaint :: fn(hwnd: usize, ps: *u8) -> bool;
#extern("user32", "InvalidateRect")     InvalidateRect :: fn(hwnd: usize, rect: ?*RECT, erase: bool) -> bool;
#extern("user32", "FillRect")           FillRect :: fn(hdc: usize, rect: *RECT, brush: usize) -> i32;
#extern("user32", "FrameRect")          FrameRect :: fn(hdc: usize, rect: *RECT, brush: usize) -> i32;
#extern("user32", "SetWindowLongPtrA")  SetWindowLongPtrA :: fn(hwnd: usize, index: i32, val: isize) -> isize;
#extern("user32", "GetWindowLongPtrA")  GetWindowLongPtrA :: fn(hwnd: usize, index: i32) -> isize;
#extern("user32", "MessageBoxA")        MessageBoxA :: fn(hwnd: usize, text: *const u8, cap: *const u8, ty: u32) -> i32;
#extern("user32", "SetWindowTextA")     SetWindowTextA :: fn(hwnd: usize, text: *const u8) -> bool;
#extern("user32", "SetTimer")           SetTimer :: fn(hwnd: usize, id: usize, ms: u32, proc: ?*void) -> usize;
#extern("user32", "KillTimer")          KillTimer :: fn(hwnd: usize, id: usize) -> bool;

#extern("gdi32", "SetTextColor")     SetTextColor :: fn(hdc: usize, color: u32) -> u32;
#extern("gdi32", "SetBkMode")        SetBkMode :: fn(hdc: usize, mode: i32) -> i32;
#extern("gdi32", "TextOutA")         TextOutA :: fn(hdc: usize, x: i32, y: i32, s: *const u8, n: i32) -> bool;
#extern("gdi32", "CreateSolidBrush") CreateSolidBrush :: fn(color: u32) -> usize;
#extern("gdi32", "GetStockObject")   GetStockObject :: fn(i: i32) -> usize;
#extern("gdi32", "SetDCBrushColor")  SetDCBrushColor :: fn(hdc: usize, color: u32) -> u32;
#extern("gdi32", "CreateFontA")      CreateFontA :: fn(h: i32, w: i32, esc: i32, orient: i32, weight: i32, italic: u32, underline: u32, strike: u32, charset: u32, op: u32, cp: u32, q: u32, pf: u32, face: *const u8) -> usize;
#extern("gdi32", "SelectObject")     SelectObject :: fn(hdc: usize, obj: usize) -> usize;
#extern("gdi32", "CreateCompatibleDC")     CreateCompatibleDC :: fn(hdc: usize) -> usize;
#extern("gdi32", "CreateCompatibleBitmap") CreateCompatibleBitmap :: fn(hdc: usize, w: i32, h: i32) -> usize;
#extern("gdi32", "BitBlt")     BitBlt :: fn(dst: usize, x: i32, y: i32, w: i32, h: i32, src: usize, sx: i32, sy: i32, rop: u32) -> bool;
#extern("gdi32", "DeleteDC")     DeleteDC :: fn(dc: usize) -> bool;
#extern("gdi32", "DeleteObject") DeleteObject :: fn(obj: usize) -> bool;

#extern("shell32", "SHFileOperationA") SHFileOperationA :: fn(op: *SHFILEOP) -> i32;
#extern("shell32", "ShellExecuteA")    ShellExecuteA :: fn(hwnd: usize, op: ?*const u8, file: *const u8, params: ?*const u8, dir: ?*const u8, show: i32) -> usize;

// CreateThread comes from the win32 module (already in the program via scan) —
// import it rather than re-declaring the kernel32 symbol.
#import win32.{ CreateThread };

WNDCLASSEXA :: struct {
    cbSize: u32, style: u32,
    wndproc: fn(usize, u32, usize, isize) -> isize,
    cbClsExtra: i32, cbWndExtra: i32,
    hInstance: usize, hIcon: usize, hCursor: usize, hbrBackground: usize,
    menuName: ?*const u8, className: *const u8, hIconSm: usize,
}
MSG    :: struct { hwnd: usize, message: u32, wParam: usize, lParam: isize, time: u32, pt_x: i32, pt_y: i32 }
RECT   :: struct { left: i32, top: i32, right: i32, bottom: i32 }
SHFILEOP :: struct {
    hwnd: usize, func: u32, from: *const u8, to: ?*const u8,
    flags: u16, aborted: i32, nameMappings: ?*void, progressTitle: ?*const u8,
}
HitBox :: struct { x: i32, y: i32, w: i32, h: i32, node: *Node }

WM_DESTROY :: 2u32; WM_PAINT :: 15u32; WM_KEYDOWN :: 256u32; WM_SIZE :: 5u32; WM_TIMER :: 275u32;
WM_LBUTTONDOWN :: 513u32; WM_LBUTTONDBLCLK :: 515u32; WM_MOUSEWHEEL :: 522u32; WM_MOUSEMOVE :: 512u32;
WM_ERASEBKGND :: 20u32; SRCCOPY :: 0x00CC0020u32;
GWLP_USERDATA :: -21;
VK_TAB :: 9u32; VK_BACK :: 8u32; VK_RETURN :: 13u32; VK_ESCAPE :: 27u32; VK_PRIOR :: 33u32; VK_NEXT :: 34u32;
VK_END :: 35u32; VK_HOME :: 36u32; VK_UP :: 38u32; VK_DOWN :: 40u32; VK_DELETE :: 46u32;
VK_F5 :: 116u32; VK_O :: 79u32;
MB_YESNO :: 4u32; MB_ICONWARNING :: 0x30u32; IDYES :: 6;
DC_BRUSH :: 18;

LINE_H :: 19; HEAD_H :: 44; FOOT_H :: 44; LIST_W :: 360; MAXD :: 8; MINCELL :: 3;
NHITS :: 20000;

State :: struct {
    arena:  *Arena,
    root:   *Node,
    cur:    *Node,
    hwnd:   usize,
    sel:    i32, scroll: i32, rows: i32,
    width:  i32, height: i32,
    view:   i32,          // 0 = split, 1 = treemap only, 2 = list only
    mx:     i32, my: i32,
    hover:  ?*Node,
    anim:   f64, animating: bool,
    hits:   []HitBox, nhits: usize,
    font:   usize, dcbrush: usize,
    br_bg:  usize, br_sel: usize, br_bar: usize, br_head: usize, br_border: usize, br_hover: usize, br_pane: usize,
    // background scan
    scanning: bool, was_scanning: bool, spin: i32,
    scan_path: []const u8, files: u64, dirs: u64,
    // double-buffer
    mem_dc: usize, mem_bmp: usize, mem_w: i32, mem_h: i32,
}

rgb :: fn(r: u32, g: u32, b: u32) -> u32 { return r | (g << 8u32) | (b << 16u32); }
fmin :: fn(a: f64, b: f64) -> f64 { if a < b { return a; } return b; }
scale_rgb :: fn(c: u32, f: f64) -> u32 {
    r := ((c & 0xFFu32) as f64) * f;
    g := (((c >> 8u32) & 0xFFu32) as f64) * f;
    b := (((c >> 16u32) & 0xFFu32) as f64) * f;
    return (r as u32) | ((g as u32) << 8u32) | ((b as u32) << 16u32);
}

// ── colour by file type ──────────────────────────────────────────────────────
ext_of :: fn(name: []const u8) -> []const u8 {
    i: usize = name.len;
    while i > 0usize { i = i - 1usize; if name[i] == 46u8 { return name[(i + 1usize)..name.len]; } }
    return name[0usize..0usize];
}
lc :: fn(b: u8) -> u8 { if b >= 65u8 { if b <= 90u8 { return b + 32u8; } } return b; }
ext_is :: fn(e: []const u8, s: []const u8) -> bool {
    if e.len != s.len { return false; }
    i: usize = 0usize;
    while i < e.len { if lc(e[i]) != s[i] { return false; } i = i + 1usize; }
    return true;
}
in3 :: fn(e: []const u8, a: []const u8, b: []const u8, c: []const u8) -> bool {
    if ext_is(e, a) { return true; } if ext_is(e, b) { return true; } return ext_is(e, c);
}
color_for :: fn(n: *Node) -> u32 {
    if n.is_dir { return rgb(96u32, 104u32, 120u32); }
    e := ext_of(n.name);
    if in3(e, "k2", "zig", "c")       { return rgb(86u32, 154u32, 220u32); }   // code (blue)
    if in3(e, "h", "rs", "py")        { return rgb(86u32, 154u32, 220u32); }
    if in3(e, "js", "ts", "go")       { return rgb(86u32, 154u32, 220u32); }
    if in3(e, "png", "jpg", "jpeg")   { return rgb(96u32, 196u32, 120u32); }   // image (green)
    if in3(e, "gif", "bmp", "svg")    { return rgb(96u32, 196u32, 120u32); }
    if in3(e, "mp4", "mkv", "mov")    { return rgb(170u32, 120u32, 210u32); }  // video (purple)
    if in3(e, "avi", "webm", "wmv")   { return rgb(170u32, 120u32, 210u32); }
    if in3(e, "mp3", "wav", "flac")   { return rgb(225u32, 120u32, 170u32); }  // audio (pink)
    if in3(e, "zip", "7z", "rar")     { return rgb(230u32, 160u32, 70u32); }   // archive (orange)
    if in3(e, "gz", "tar", "xz")      { return rgb(230u32, 160u32, 70u32); }
    if in3(e, "exe", "dll", "sys")    { return rgb(220u32, 90u32, 80u32); }    // binary (red)
    if in3(e, "o", "obj", "lib")      { return rgb(220u32, 90u32, 80u32); }
    if in3(e, "txt", "md", "pdf")     { return rgb(90u32, 200u32, 200u32); }   // docs (teal)
    if in3(e, "json", "xml", "csv")   { return rgb(220u32, 200u32, 90u32); }   // data (yellow)
    return rgb(150u32, 150u32, 155u32);                                        // other (grey)
}

// ── tiny allocation-free formatting into a stack buffer ──────────────────────
put :: fn(buf: []u8, pos: usize, s: []const u8) -> usize {
    i: usize = 0usize;
    while i < s.len { if pos + i < buf.len { buf[pos + i] = s[i]; } i = i + 1usize; }
    return pos + s.len;
}
put_u64 :: fn(buf: []u8, pos: usize, v: u64) -> usize {
    if v == 0u64 { if pos < buf.len { buf[pos] = 48u8; } return pos + 1usize; }
    tmp: [24]u8 = .{};
    n: usize = 0usize; x: u64 = v;
    while x > 0u64 { tmp[n] = (48u64 + (x % 10u64)) as u8; x = x / 10u64; n = n + 1usize; }
    i: usize = 0usize;
    while i < n { if pos + i < buf.len { buf[pos + i] = tmp[n - 1usize - i]; } i = i + 1usize; }
    return pos + n;
}
put_size :: fn(buf: []u8, pos: usize, b: u64) -> usize {
    KB: u64 = 1024u64; MB: u64 = 1048576u64; GB: u64 = 1073741824u64; TB: u64 = 1099511627776u64;
    div: u64 = 1u64; suf: []const u8 = " B";
    if b >= TB { div = TB; suf = " TB"; }
    else { if b >= GB { div = GB; suf = " GB"; }
    else { if b >= MB { div = MB; suf = " MB"; }
    else { if b >= KB { div = KB; suf = " KB"; } } } }
    if div == 1u64 { p := put_u64(buf, pos, b); return put(buf, p, suf); }
    p := put_u64(buf, pos, b / div);
    if p < buf.len { buf[p] = 46u8; } p = p + 1usize;
    p = put_u64(buf, p, (b % div) * 10u64 / div);
    return put(buf, p, suf);
}
draw :: fn(hdc: usize, x: i32, y: i32, buf: []u8, n: usize) {
    if n == 0usize { return; }
    p := unsafe ((&buf[0]) as *const u8);
    ignored := TextOutA(hdc, x, y, p, n as i32);
}

nth_live :: fn(cur: *Node, n: i32) -> ?*Node {
    seen: i32 = 0; i: usize = 0usize;
    while i < cur.kids.len {
        c := cur.kids[i];
        if !c.deleted { if seen == n { return c; } seen = seen + 1; }
        i = i + 1usize;
    }
    return null;
}
build_path :: fn(cur: *Node, buf: []u8) -> usize {
    chain: [64]*Node = .{};
    n: usize = 0usize; p: ?*Node = cur; cont: bool = true;
    while cont { if p |pp| { if n < 64usize { chain[n] = pp; n = n + 1usize; } p = pp.parent; } else { cont = false; } }
    pos: usize = 0usize; i: usize = n;
    while i > 0usize {
        i = i - 1usize; nd := chain[i];
        pos = put(buf, pos, nd.name);
        if i > 0usize {
            last: bool = false;
            if pos > 0usize { if buf[pos - 1usize] == 92u8 { last = true; } }
            if !last { if pos < buf.len { buf[pos] = 92u8; } pos = pos + 1usize; }
        }
    }
    return pos;
}

// ── squarified treemap ───────────────────────────────────────────────────────
row_worst :: fn(items: []*Node, lo: usize, hi: usize, scale: f64, side: f64) -> f64 {
    sum: u64 = 0u64; k: usize = lo;
    while k < hi { sum = sum + items[k].size; k = k + 1usize; }
    rowarea := (sum as f64) * scale;
    if rowarea <= 0.0 { return 1000000.0; }
    thick := rowarea / side;
    if thick <= 0.0 { return 1000000.0; }
    worst := 1.0;
    k = lo;
    while k < hi {
        a := (items[k].size as f64) * scale;
        if a > 0.0 {
            ln := a / thick;
            ar := thick / ln;
            if ar < 1.0 { ar = 1.0 / ar; }
            if ar > worst { worst = ar; }
        }
        k = k + 1usize;
    }
    return worst;
}
draw_cell :: fn(s: *State, hdc: usize, n: *Node, x: f64, y: f64, w: f64, h: f64, depth: i32) {
    if w < (MINCELL as f64) { return; }
    if h < (MINCELL as f64) { return; }
    ix := x as i32; iy := y as i32; iw := w as i32; ih := h as i32;
    r: RECT = .{ ix, iy, ix + iw, iy + ih };
    if n.is_dir { if depth < MAXD { if w > 14.0 { if h > 14.0 {
        finalize(s.arena, n);
        ig := SetDCBrushColor(hdc, scale_rgb(rgb(40u32, 44u32, 52u32), s.anim));
        ig2 := FillRect(hdc, &r, s.dcbrush);
        treemap(s, hdc, n.kids, x + 1.0, y + 1.0, w - 2.0, h - 2.0, n.size, depth + 1i32);
        ig3 := FrameRect(hdc, &r, s.br_border);
        return;
    } } } }
    // leaf
    ig4 := SetDCBrushColor(hdc, scale_rgb(color_for(n), s.anim));
    ig5 := FillRect(hdc, &r, s.dcbrush);
    if iw > 3i32 { if ih > 3i32 { ig6 := FrameRect(hdc, &r, s.br_border); } }
    if s.nhits < s.hits.len { s.hits[s.nhits] = .{ ix, iy, iw, ih, n }; s.nhits = s.nhits + 1usize; }
    if s.hover |hv| { if hv == n { ig7 := FrameRect(hdc, &r, s.br_hover); } }
}
treemap :: fn(s: *State, hdc: usize, items: []*Node, x: f64, y: f64, w: f64, h: f64, total: u64, depth: i32) {
    if w < 1.0 { return; } if h < 1.0 { return; } if total == 0u64 { return; }
    // effective count: sorted desc, stop at first deleted/zero
    n: usize = 0usize;
    while n < items.len { c := items[n]; if c.deleted { break; } if c.size == 0u64 { break; } n = n + 1usize; }
    if n == 0usize { return; }
    scale := (w * h) / (total as f64);
    rx := x; ry := y; rw := w; rh := h;
    i: usize = 0usize;
    while i < n {
        side := fmin(rw, rh);
        if side < 1.0 { return; }
        j := i + 1usize;
        best := row_worst(items, i, j, scale, side);
        cont: bool = true;
        while cont {
            if j >= n { cont = false; }
            else {
                wnew := row_worst(items, i, j + 1usize, scale, side);
                if wnew <= best { best = wnew; j = j + 1usize; } else { cont = false; }
            }
        }
        rowsz: u64 = 0u64; k: usize = i;
        while k < j { rowsz = rowsz + items[k].size; k = k + 1usize; }
        thick := ((rowsz as f64) * scale) / side;
        pos := 0.0;
        k = i;
        while k < j {
            a := (items[k].size as f64) * scale;
            ln := a / thick;
            if rw >= rh { draw_cell(s, hdc, items[k], rx, ry + pos, thick, ln, depth); }
            else        { draw_cell(s, hdc, items[k], rx + pos, ry, ln, thick, depth); }
            pos = pos + ln;
            k = k + 1usize;
        }
        if rw >= rh { rx = rx + thick; rw = rw - thick; } else { ry = ry + thick; rh = rh - thick; }
        i = j;
    }
}

hit_test :: fn(s: *State, x: i32, y: i32) -> ?*Node {
    i: usize = s.nhits;
    while i > 0usize {
        i = i - 1usize;
        hb := s.hits[i];
        if x >= hb.x { if x < hb.x + hb.w { if y >= hb.y { if y < hb.y + hb.h { return hb.node; } } } }
    }
    return null;
}

// ── window procedure ─────────────────────────────────────────────────────────
wndproc :: fn(hwnd: usize, msg: u32, wp: usize, lp: isize) -> isize {
    sp := GetWindowLongPtrA(hwnd, GWLP_USERDATA);
    if sp == 0isize { return DefWindowProcA(hwnd, msg, wp, lp); }
    s := unsafe (sp as *State);

    if msg == WM_DESTROY { PostQuitMessage(0); return 0isize; }
    if msg == WM_ERASEBKGND { return 1isize; }   // we paint every pixel (double-buffered) → no erase flicker
    if msg == WM_SIZE {
        s.width = (lp & 0xFFFFisize) as i32;
        s.height = ((lp >> 16isize) & 0xFFFFisize) as i32;
        s.rows = (s.height - HEAD_H - FOOT_H) / LINE_H;
        ignored := InvalidateRect(hwnd, null, false);
        return 0isize;
    }
    if msg == WM_TIMER {
        if s.scanning {
            s.spin = s.spin + 1i32;                  // animate the scanning spinner
            ignored := InvalidateRect(hwnd, null, false);
        } else { if s.was_scanning {
            s.was_scanning = false;                  // scan just finished → reveal + grow-in
            s.anim = 0.05; set_title(s);
            ignored2 := InvalidateRect(hwnd, null, false);
        } else {
            s.anim = s.anim + 0.12;
            if s.anim >= 1.0 { s.anim = 1.0; s.animating = false; ig := KillTimer(hwnd, 1usize); }
            ignored3 := InvalidateRect(hwnd, null, false);
        } }
        return 0isize;
    }
    if msg == WM_PAINT { paint(s, hwnd); return 0isize; }
    if msg == WM_MOUSEMOVE {
        s.mx = (lp & 0xFFFFisize) as i32;
        s.my = ((lp >> 16isize) & 0xFFFFisize) as i32;
        nh := hit_test(s, s.mx, s.my);
        changed: bool = true;
        if nh |a| { if s.hover |b| { if a == b { changed = false; } } }
        else { if s.hover |b| { changed = true; } else { changed = false; } }
        s.hover = nh;
        if changed { ignored := InvalidateRect(hwnd, null, false); }
        return 0isize;
    }
    if msg == WM_LBUTTONDOWN {
        x := (lp & 0xFFFFisize) as i32;
        y := ((lp >> 16isize) & 0xFFFFisize) as i32;
        if x < LIST_W { if s.view != 1i32 {
            row := (y - HEAD_H) / LINE_H;
            if row >= 0i32 { s.sel = s.scroll + row; clamp_sel(s); ignored := InvalidateRect(hwnd, null, false); }
        } } else {
            if hit_test(s, x, y) |hitn| { jump_to(s, hitn); }
        }
        return 0isize;
    }
    if msg == WM_LBUTTONDBLCLK { descend(s); kick(s); return 0isize; }
    if msg == WM_MOUSEWHEEL {
        d := (((wp >> 16usize) & 0xFFFFusize) as i32);
        if d > 32768i32 { s.scroll = s.scroll + 3i32; } else { s.scroll = s.scroll - 3i32; }
        clamp_scroll(s);
        ignored := InvalidateRect(hwnd, null, false);
        return 0isize;
    }
    if msg == WM_KEYDOWN {
        key := wp as u32;
        if key == VK_UP    { s.sel = s.sel - 1i32; clamp_sel(s); ensure_visible(s); }
        if key == VK_DOWN  { s.sel = s.sel + 1i32; clamp_sel(s); ensure_visible(s); }
        if key == VK_PRIOR { s.sel = s.sel - s.rows; clamp_sel(s); ensure_visible(s); }
        if key == VK_NEXT  { s.sel = s.sel + s.rows; clamp_sel(s); ensure_visible(s); }
        if key == VK_HOME  { s.sel = 0i32; ensure_visible(s); }
        if key == VK_END   { s.sel = (live_children(s.cur) as i32) - 1i32; clamp_sel(s); ensure_visible(s); }
        if key == VK_RETURN { descend(s); kick(s); }
        if key == VK_BACK  { ascend(s); kick(s); }
        if key == VK_DELETE { do_delete(s); }
        if key == VK_TAB   { s.view = (s.view + 1i32) % 3i32; }
        if key == VK_F5    { rescan(s); }
        if key == VK_O     { open_in_explorer(s); }
        if key == VK_ESCAPE { PostQuitMessage(0); }
        ignored := InvalidateRect(hwnd, null, false);
        return 0isize;
    }
    return DefWindowProcA(hwnd, msg, wp, lp);
}

kick :: fn(s: *State) {
    s.anim = 0.08; s.animating = true;
    ig := SetTimer(s.hwnd, 1usize, 16u32, null);
    ignored := InvalidateRect(s.hwnd, null, false);
}
// F5 — re-run the scan from scratch on a background thread.
rescan :: fn(s: *State) {
    if s.scanning { return; }
    s.scanning = true; s.was_scanning = true; s.spin = 0i32;
    ig := SetTimer(s.hwnd, 1usize, 16u32, null);
    pp := unsafe ((s) as *void);
    th := CreateThread(null, 0usize, scan_worker, pp, 0u32, null);
    ignored := InvalidateRect(s.hwnd, null, false);
}
// O — open the current directory in Explorer.
open_in_explorer :: fn(s: *State) {
    if s.scanning { return; }
    path: [4096]u8 = .{};
    pl := build_path(s.cur, path[:]);
    if pl < path.len { path[pl] = 0u8; }
    pp := unsafe ((&path[0]) as *const u8);
    opb: [8]u8 = .{ 111u8, 112u8, 101u8, 110u8, 0u8, 0u8, 0u8, 0u8 };   // "open"
    op := unsafe ((&opb[0]) as *const u8);
    ig := ShellExecuteA(s.hwnd, op, pp, null, null, 1i32);
}
clamp_sel :: fn(s: *State) {
    n := live_children(s.cur) as i32;
    if s.sel >= n { s.sel = n - 1i32; } if s.sel < 0i32 { s.sel = 0i32; }
}
clamp_scroll :: fn(s: *State) {
    n := live_children(s.cur) as i32; maxs := n - s.rows;
    if s.scroll > maxs { s.scroll = maxs; } if s.scroll < 0i32 { s.scroll = 0i32; }
}
ensure_visible :: fn(s: *State) {
    if s.sel < s.scroll { s.scroll = s.sel; }
    if s.sel >= s.scroll + s.rows { s.scroll = s.sel - s.rows + 1i32; }
    clamp_scroll(s);
}
descend :: fn(s: *State) {
    if nth_live(s.cur, s.sel) |c| { if c.is_dir { finalize(s.arena, c); s.cur = c; s.sel = 0i32; s.scroll = 0i32; set_title(s); } }
}
ascend :: fn(s: *State) {
    if s.cur.parent |p| { s.cur = p; s.sel = 0i32; s.scroll = 0i32; set_title(s); }
}
// click on a treemap block: jump to the folder that contains it
jump_to :: fn(s: *State, n: *Node) {
    dest: ?*Node = n.parent;
    if n.is_dir { dest = n; }
    if dest |d| { finalize(s.arena, d); s.cur = d; s.sel = 0i32; s.scroll = 0i32; set_title(s); kick(s); }
}
set_title :: fn(s: *State) {
    buf: [4096]u8 = .{};
    pos := build_path(s.cur, buf[:]);
    if pos < buf.len { buf[pos] = 0u8; }
    tp := unsafe ((&buf[0]) as *const u8);
    ignored := SetWindowTextA(s.hwnd, tp);
}
do_delete :: fn(s: *State) {
    if nth_live(s.cur, s.sel) |c| {
        path: [4096]u8 = .{};
        plen := build_path(c, path[:]);
        if plen + 2usize < path.len { path[plen] = 0u8; path[plen + 1usize] = 0u8; }
        m: [4200]u8 = .{};
        mp0 := put(m[:], 0usize, "Send to the Recycle Bin?\n\n");
        mp0 = put(m[:], mp0, path[0usize..plen]);
        mp0 = put(m[:], mp0, "\n\n");
        mp0 = put_size(m[:], mp0, c.size);
        if mp0 < m.len { m[mp0] = 0u8; }
        mptr := unsafe ((&m[0]) as *const u8);
        capb: [8]u8 = .{ 68u8, 101u8, 108u8, 101u8, 116u8, 101u8, 0u8, 0u8 };
        cap := unsafe ((&capb[0]) as *const u8);
        if MessageBoxA(s.hwnd, mptr, cap, MB_YESNO | MB_ICONWARNING) == IDYES {
            pp := unsafe ((&path[0]) as *const u8);
            op: SHFILEOP = .{ s.hwnd, 3u32, pp, null, 0x50u16, 0i32, null, null };
            if SHFileOperationA(&op) == 0i32 { mark_deleted(c); clamp_sel(s); }
        }
    }
}

// ── painting ─────────────────────────────────────────────────────────────────
LEGEND_N :: 8;
legend_name :: fn(i: i32) -> []const u8 {
    if i == 0i32 { return "code"; } if i == 1i32 { return "image"; } if i == 2i32 { return "video"; }
    if i == 3i32 { return "audio"; } if i == 4i32 { return "archive"; } if i == 5i32 { return "binary"; }
    if i == 6i32 { return "docs"; } return "data";
}
legend_color :: fn(i: i32) -> u32 {
    if i == 0i32 { return rgb(86u32, 154u32, 220u32); } if i == 1i32 { return rgb(96u32, 196u32, 120u32); }
    if i == 2i32 { return rgb(170u32, 120u32, 210u32); } if i == 3i32 { return rgb(225u32, 120u32, 170u32); }
    if i == 4i32 { return rgb(230u32, 160u32, 70u32); } if i == 5i32 { return rgb(220u32, 90u32, 80u32); }
    if i == 6i32 { return rgb(90u32, 200u32, 200u32); } return rgb(220u32, 200u32, 90u32);
}

// Make sure the off-screen buffer matches the window size.
ensure_buffer :: fn(s: *State, wdc: usize) {
    if s.mem_dc == 0usize { s.mem_dc = CreateCompatibleDC(wdc); }
    if s.mem_w != s.width { s.mem_w = -1i32; }
    if s.mem_h != s.height { s.mem_h = -1i32; }
    if s.mem_w < 0i32 {
        if s.mem_bmp != 0usize { ig := DeleteObject(s.mem_bmp); }
        s.mem_bmp = CreateCompatibleBitmap(wdc, s.width, s.height);
        s.mem_w = s.width; s.mem_h = s.height;
    }
}

// Double-buffered paint: render the whole frame to an off-screen bitmap, then
// blit it in one BitBlt. No flicker, no visible partial redraw.
paint :: fn(s: *State, hwnd: usize) {
    ps: [80]u8 = .{};
    wdc := BeginPaint(hwnd, &ps[0]);
    ensure_buffer(s, wdc);
    mdc := s.mem_dc;
    old := SelectObject(mdc, s.mem_bmp);
    ig0 := SelectObject(mdc, s.font);
    ig1 := SetBkMode(mdc, 1i32);

    if s.scanning { paint_scanning(s, mdc); } else { paint_browse(s, mdc); }

    igb := BitBlt(wdc, 0i32, 0i32, s.width, s.height, mdc, 0i32, 0i32, SRCCOPY);
    ig2 := SelectObject(mdc, old);
    igE := EndPaint(hwnd, &ps[0]);
}

spin_char :: fn(i: i32) -> u8 {
    m := i % 4i32;
    if m == 0i32 { return 124u8; }   // |
    if m == 1i32 { return 47u8; }    // /
    if m == 2i32 { return 45u8; }    // -
    return 92u8;                     // \
}

paint_scanning :: fn(s: *State, mdc: usize) {
    full: RECT = .{ 0i32, 0i32, s.width, s.height };
    ig := FillRect(mdc, &full, s.br_bg);
    cx := s.width / 2i32 - 150i32;
    cy := s.height / 2i32 - 24i32;
    buf: [4096]u8 = .{};
    sb: usize = 0usize;
    sb = put(buf[:], sb, "Scanning ");
    if sb < buf.len { buf[sb] = spin_char(s.spin); } sb = sb + 1usize;
    ig2 := SetTextColor(mdc, rgb(235u32, 235u32, 240u32));
    draw(mdc, cx, cy, buf[:], sb);
    ig3 := SetTextColor(mdc, rgb(150u32, 200u32, 255u32));
    draw(mdc, cx, cy + 22i32, s.scan_path, s.scan_path.len);
    ig4 := SetTextColor(mdc, rgb(130u32, 130u32, 135u32));
    draw(mdc, cx, cy + 48i32, "reading the directory tree — large drives can take a moment", 58usize);
    // a little indeterminate progress sweep
    pw: i32 = 260i32;
    bx := cx; by := cy + 76i32;
    track: RECT = .{ bx, by, bx + pw, by + 6i32 };
    igt := FillRect(mdc, &track, s.br_head);
    px := bx + ((s.spin * 12i32) % (pw - 50i32));
    knob: RECT = .{ px, by, px + 50i32, by + 6i32 };
    igk := SetDCBrushColor(mdc, rgb(86u32, 154u32, 220u32));
    igk2 := FillRect(mdc, &knob, s.dcbrush);
}

paint_browse :: fn(s: *State, mdc: usize) {
    s.nhits = 0usize;
    full: RECT = .{ 0i32, 0i32, s.width, s.height };
    ig := FillRect(mdc, &full, s.br_bg);
    head: RECT = .{ 0i32, 0i32, s.width, HEAD_H };
    ig2 := FillRect(mdc, &head, s.br_head);

    buf: [4096]u8 = .{};
    ig3 := SetTextColor(mdc, rgb(235u32, 235u32, 235u32));
    plen := build_path(s.cur, buf[:]);
    draw(mdc, 12i32, 6i32, buf[:], plen);
    h2 := put_size(buf[:], 0usize, s.cur.size);
    h2 = put(buf[:], h2, "   ");
    h2 = put_u64(buf[:], h2, live_children(s.cur) as u64);
    h2 = put(buf[:], h2, " items    Tab: view  Enter: open  Bksp: up  Del: recycle  F5: rescan  O: explorer");
    ig4 := SetTextColor(mdc, rgb(150u32, 150u32, 155u32));
    draw(mdc, 12i32, 25i32, buf[:], h2);

    list_w: i32 = LIST_W;
    if s.view == 1i32 { list_w = 0i32; }
    if s.view == 2i32 { list_w = s.width; }

    if list_w > 0i32 { paint_list(s, mdc, list_w); }

    if s.view != 2i32 {
        tx := list_w; if list_w > 0i32 { tx = list_w + 1i32; }
        tw := s.width - tx;
        ty := HEAD_H; th := s.height - HEAD_H - FOOT_H;
        if tw > 8i32 { if th > 8i32 {
            pane: RECT = .{ tx, ty, tx + tw, ty + th };
            igp := FillRect(mdc, &pane, s.br_pane);
            treemap(s, mdc, s.cur.kids, (tx + 1i32) as f64, (ty + 1i32) as f64, (tw - 2i32) as f64, (th - 2i32) as f64, s.cur.size, 0i32);
        } }
    }

    paint_footer(s, mdc);
}

paint_list :: fn(s: *State, hdc: usize, list_w: i32) {
    buf: [1024]u8 = .{};
    total := s.cur.size; if total == 0u64 { total = 1u64; }
    vis: i32 = 0; seen: i32 = 0; i: usize = 0usize;
    while i < s.cur.kids.len {
        c := s.cur.kids[i];
        if !c.deleted {
            if seen >= s.scroll { if vis < s.rows {
                y := HEAD_H + vis * LINE_H;
                if seen == s.sel {
                    rr: RECT = .{ 0i32, y, list_w, y + LINE_H };
                    ig := FillRect(hdc, &rr, s.br_sel);
                }
                pct := (c.size * 100u64) / total;
                pb: usize = 0usize;
                if pct < 10u64 { pb = put(buf[:], pb, "  "); } else { if pct < 100u64 { pb = put(buf[:], pb, " "); } }
                pb = put_u64(buf[:], pb, pct); pb = put(buf[:], pb, "%");
                ig1 := SetTextColor(hdc, rgb(140u32, 160u32, 200u32));
                draw(hdc, 10i32, y + 2i32, buf[:], pb);
                sb := put_size(buf[:], 0usize, c.size);
                ig2 := SetTextColor(hdc, rgb(210u32, 210u32, 210u32));
                draw(hdc, 56i32, y + 2i32, buf[:], sb);
                // bar (grows in with the animation)
                bw := (((c.size * 120u64) / total) as i32);
                bw = ((bw as f64) * s.anim) as i32;
                if bw < 1i32 { bw = 1i32; }
                bar: RECT = .{ 150i32, y + 4i32, 150i32 + bw, y + LINE_H - 4i32 };
                igb := SetDCBrushColor(hdc, color_for(c));
                igb2 := FillRect(hdc, &bar, s.dcbrush);
                if c.is_dir { ig3 := SetTextColor(hdc, rgb(120u32, 200u32, 255u32)); }
                else        { ig4 := SetTextColor(hdc, rgb(205u32, 205u32, 205u32)); }
                nb: usize = 0usize;
                if c.is_dir { nb = put(buf[:], nb, "+ "); } else { nb = put(buf[:], nb, "  "); }
                nb = put(buf[:], nb, c.name);
                draw(hdc, 276i32, y + 2i32, buf[:], nb);
                vis = vis + 1i32;
            } }
            seen = seen + 1;
        }
        i = i + 1usize;
    }
}

paint_footer :: fn(s: *State, hdc: usize) {
    fy := s.height - FOOT_H;
    foot: RECT = .{ 0i32, fy, s.width, s.height };
    ig := FillRect(hdc, &foot, s.br_head);
    buf: [1024]u8 = .{};
    // hovered item path + size, else legend prompt
    ig2 := SetTextColor(hdc, rgb(225u32, 225u32, 225u32));
    if s.hover |hv| {
        pl := build_path(hv, buf[:]);
        draw(hdc, 12i32, fy + 4i32, buf[:], pl);
        sl := put_size(buf[:], 0usize, hv.size);
        ig3 := SetTextColor(hdc, rgb(150u32, 200u32, 255u32));
        draw(hdc, 12i32, fy + 23i32, buf[:], sl);
    } else {
        draw(hdc, 12i32, fy + 4i32, "hover a block to inspect it · click to jump to its folder", 56usize);
    }
    // legend along the bottom-right
    lx: i32 = s.width - 560i32;
    if lx < 360i32 { lx = 360i32; }
    i: i32 = 0i32;
    while i < LEGEND_N {
        sw: RECT = .{ lx, fy + 26i32, lx + 11i32, fy + 37i32 };
        igc := SetDCBrushColor(hdc, legend_color(i));
        igf := FillRect(hdc, &sw, s.dcbrush);
        ig5 := SetTextColor(hdc, rgb(170u32, 170u32, 175u32));
        nm := legend_name(i);
        draw(hdc, lx + 15i32, fy + 25i32, nm, nm.len);
        lx = lx + 70i32;
        i = i + 1i32;
    }
}

cstr :: fn(s: []const u8, buf: []u8) -> *const u8 {
    i: usize = 0usize;
    while i < s.len { buf[i] = s[i]; i = i + 1usize; }
    buf[i] = 0u8;
    return unsafe ((&buf[0]) as *const u8);
}
first_arg :: fn(line: []const u8, def: []const u8) -> []const u8 {
    i: usize = 0usize;
    if line.len > 0usize {
        if line[0] == 34u8 { i = 1usize; while i < line.len { q: bool = line[i] == 34u8; i += 1usize; if q { break; } } }
        else { while i < line.len { if line[i] == 32u8 { break; } i += 1usize; } }
    }
    while i < line.len { if line[i] != 32u8 { break; } i += 1usize; }
    if i >= line.len { return def; }
    if line[i] == 34u8 {
        i = i + 1usize; start: usize = i;
        while i < line.len { if line[i] == 34u8 { break; } i += 1usize; }
        return line[start..i];
    }
    start: usize = i;
    while i < line.len { if line[i] == 32u8 { break; } i += 1usize; }
    return line[start..i];
}

// Background scan: runs on its own thread so the window appears instantly. Sets
// `scanning = false` last, after the tree is fully built and finalized.
scan_worker :: fn(param: *void) -> u32 {
    s := unsafe (param as *State);
    st: Stats = .{ 0u64, 0u64 };
    r := scan(s.arena, s.scan_path, &st);
    finalize(s.arena, r);
    s.root = r; s.cur = r;
    s.files = st.files; s.dirs = st.dirs;
    s.scanning = false;
    return 0u32;
}

#entry
main :: fn() -> i32 {
    a := make();
    line_buf: [1024]u8 = .{};
    root_path := first_arg(process::command_line(line_buf[:]), "C:\\");

    hits_store := new_slice(HitBox, &a, NHITS);   // arena, not a ~480 KB stack frame
    placeholder := make_node(&a, root_path, true);

    inst := GetModuleHandleA(null);
    cbuf: [16]u8 = .{};
    cname := cstr("diskscanwin", cbuf[:]);
    facebuf: [16]u8 = .{};
    face := cstr("Consolas", facebuf[:]);
    font := CreateFontA(-14i32, 0i32, 0i32, 0i32, 400i32, 0u32, 0u32, 0u32, 0u32, 0u32, 0u32, 5u32, 1u32, face);

    s: State = .{ &a, placeholder, placeholder, 0usize,
                  0i32, 0i32, 20i32, 1100i32, 720i32,
                  0i32, 0i32, 0i32, null,
                  1.0, false,
                  hits_store, 0usize,
                  font, GetStockObject(DC_BRUSH),
                  CreateSolidBrush(rgb(24u32, 24u32, 27u32)),
                  CreateSolidBrush(rgb(48u32, 84u32, 132u32)),
                  CreateSolidBrush(rgb(70u32, 150u32, 90u32)),
                  CreateSolidBrush(rgb(34u32, 34u32, 40u32)),
                  CreateSolidBrush(rgb(15u32, 15u32, 17u32)),
                  CreateSolidBrush(rgb(255u32, 255u32, 255u32)),
                  CreateSolidBrush(rgb(18u32, 18u32, 20u32)),
                  true, true, 0i32, root_path, 0u64, 0u64,
                  0usize, 0usize, -1i32, -1i32 };

    wc: WNDCLASSEXA = .{ 80u32, 3u32, wndproc, 0i32, 0i32, inst, 0usize,
                         LoadCursorA(0usize, 32512usize), s.br_bg, null, cname, 0usize };
    ignored := RegisterClassExA(&wc);

    tbuf: [32]u8 = .{};
    title := cstr("diskscan", tbuf[:]);
    hwnd := CreateWindowExA(0u32, cname, title, 0x00CF0000u32, 90i32, 50i32, 1100i32, 760i32, 0usize, 0usize, inst, null);
    s.hwnd = hwnd;
    ignored2 := SetWindowLongPtrA(hwnd, GWLP_USERDATA, unsafe ((&s) as isize));
    set_title(&s);

    ignored3 := ShowWindow(hwnd, 1i32);
    ignored4 := UpdateWindow(hwnd);
    ig5 := SetTimer(hwnd, 1usize, 16u32, null);     // drives the scan spinner + animations

    // Kick off the scan on a background thread; the window is already up.
    pp := unsafe ((&s) as *void);
    th := CreateThread(null, 0usize, scan_worker, pp, 0u32, null);

    msg: MSG = .{ 0usize, 0u32, 0usize, 0isize, 0u32, 0i32, 0i32 };
    while GetMessageA(&msg, 0usize, 0u32, 0u32) > 0i32 {
        ignored6 := TranslateMessage(&msg);
        ignored7 := DispatchMessageA(&msg);
    }
    return 0;
}
